<CommonControls:DialogControl x:Class="Amuse.App.Dialogs.ComponentModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Amuse.App.Dialogs"
        xmlns:Controls="clr-namespace:Amuse.App.Controls"
        xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
        MinWidth="800"
        MaxWidth="800"
        Title="Component Model"
        Icon="/Images/Icon.ico"
        Style="{StaticResource {x:Type CommonControls:DialogControl}}">
    <DockPanel DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ComponentModelDialog}}}" Margin="15, 15, 15, 10">

        <!--Save/Cancel/Errors-->
        <DockPanel DockPanel.Dock="Bottom" Height="30" Margin="0,15,0,0">
            <UniformGrid DockPanel.Dock="Right" Columns="2" >
                <Button Content="Save" Command="{Binding SaveCommand}" Width="100" IsDefault="True"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </UniformGrid>
            <ItemsControl ItemsSource="{Binding Errors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="IndianRed" TextWrapping="Wrap" FontSize="11"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>

        <!--Main Content-->
        <StackPanel>

            <!--Model Settings-->
            <GroupBox Header="Settings" Padding="4">
                <StackPanel>
                    <UniformGrid Rows="1">
                        <StackPanel Margin="0,0,2,0">
                            <TextBlock Text="Backend" Style="{StaticResource FieldTextBlockStyle}"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource BackendType}}" SelectedItem="{Binding ComponentModel.Backend, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EnumComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0,2,0">
                            <TextBlock Text="Name" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBox Text="{Binding ComponentModel.Name, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="2,0,0,0">
                            <TextBlock Text="Key" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBox Text="{Binding ComponentModel.Key, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </UniformGrid>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Link" Style="{StaticResource FieldTextBlockStyle}"/>
                        <TextBox Text="{Binding ComponentModel.Link, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!--Checkpoint Settings-->
            <GroupBox Header="Component" Margin="0,10,0,0" Height="160">
                <Controls:CheckpointControl Settings="{Binding Settings}" Checkpoint="{Binding ComponentModel.Checkpoint}" Backend="{Binding ComponentModel.Backend}" SupportedTypes="{Binding CheckpointTypes, Mode=OneWay}"/>
            </GroupBox>

        </StackPanel>
    </DockPanel>
</CommonControls:DialogControl>