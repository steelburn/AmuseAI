<CommonControls:DialogControl x:Class="Amuse.App.Dialogs.GatedModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Amuse.App.Dialogs"
        xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
        mc:Ignorable="d"
        MinWidth="500"
        MaxWidth="500"
        x:Name="UI"
        Title="Gated Model Access"
        Icon="/Images/Icon.ico"
        Style="{StaticResource {x:Type CommonControls:DialogControl}}">
    <DockPanel DataContext="{Binding ElementName=UI}" Margin="15, 15, 15, 10">

        <!--Close-->
        <Grid DockPanel.Dock="Bottom" Margin="0,25,0,0">
            <UniformGrid Columns="2" Height="30" HorizontalAlignment="Right">
                <Button Content="Settings" Command="{Binding SaveCommand}" Width="100"/>
                <Button Content="Close" Command="{Binding CancelCommand}" Width="100"/>
            </UniformGrid>
        </Grid>


        <!--Message-->
        <DockPanel>
            <CommonControls:FontAwesome DockPanel.Dock="Left" Size="50" Margin="10,10,10,10" Icon="f084" IconStyle="Light" Color="{StaticResource WarningColour}" />
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0,50,0">
                <TextBlock Text="{Binding Message}" FontSize="14" TextWrapping="Wrap"/>

                <TextBlock Text="The model is publicly accessible, but you have to accept the conditions to access its files and content." FontSize="14" TextWrapping="Wrap"  Margin="0,12,0,0"/>

                <CommonControls:HyperlinkControl Label="Accept Model Terms &amp; Conditions" Link="{Binding ModelLink}" FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="{StaticResource InfoColour}"/>
            </StackPanel>
        </DockPanel>

    </DockPanel>
</CommonControls:DialogControl>