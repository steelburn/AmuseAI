<CommonControls:DialogControl x:Class="Amuse.App.Dialogs.DiffusionModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Amuse.App.Dialogs"
        xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
        xmlns:Controls="clr-namespace:Amuse.App.Controls"
        mc:Ignorable="d"
        MinWidth="1000"
        MaxWidth="1000"
        MinHeight="620"
        MaxHeight="800"
        Title="Diffusion Model"
        Icon="/Images/Icon.ico"
        Style="{StaticResource {x:Type CommonControls:DialogControl}}">
    <DockPanel DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DiffusionModelDialog}}}" Margin="15, 15, 15, 10">

        <!--Save/Cancel/Errors-->
        <DockPanel DockPanel.Dock="Bottom" Height="30" Margin="0,15,0,0">
            <UniformGrid DockPanel.Dock="Right" Columns="2" >
                <Button Content="Save" Command="{Binding SaveCommand}" Width="100" IsDefault="True"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </UniformGrid>
            <ItemsControl ItemsSource="{Binding Errors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="IndianRed" TextWrapping="Wrap" FontSize="11"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>

        <StackPanel DockPanel.Dock="Top">

            <!--Model Settings-->
            <GroupBox Header="Model" Margin="0,0,0,0">
                <UniformGrid Rows="1">
                    <StackPanel Margin="0,0,2,0">
                        <TextBlock Text="Backend" Style="{StaticResource FieldTextBlockStyle}"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource BackendType}}" SelectedItem="{Binding DiffusionModel.Backend}" IsEnabled="False" />
                    </StackPanel>
                    <StackPanel Margin="2,0,2,0">
                        <TextBlock Text="Pipeline" Style="{StaticResource FieldTextBlockStyle}"/>
                        <ComboBox ItemsSource="{Binding Settings.DiffusionPipelines}" SelectedItem="{Binding DiffusionModel.Pipeline}" IsEnabled="False"  />
                    </StackPanel>
                    <StackPanel Margin="2,0,2,0">
                        <TextBlock Text="Name" Style="{StaticResource FieldTextBlockStyle}"/>
                        <TextBox Text="{Binding DiffusionModel.Name, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>
            </GroupBox>


            <UniformGrid Rows="1" Margin="0,6,0,0">

                <!--Process Settings-->
                <GroupBox DockPanel.Dock="Top" Header="Supported Functions" Margin="0,0,4,0">
                    <Grid Margin="4">
                        <StackPanel VerticalAlignment="Top"  Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Image}">
                            <UniformGrid Columns="3" >
                                <CheckBox x:Name="CheckBoxTextToImage" Content="TextToImage" />
                                <CheckBox x:Name="CheckBoxImageToImage" Content="ImageToImage" />
                                <CheckBox x:Name="CheckBoxImageEdit" Content="ImageEdit" />
                                <CheckBox x:Name="CheckBoxImageInpaint" Content="ImageInpaint" />
                                <CheckBox x:Name="CheckBoxImageControlNet" Content="Image (ControlNet)" />
                                <CheckBox x:Name="CheckBoxImageToImageControlNet" Content="ImageToImage (ControlNet)" />
                            </UniformGrid>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Top"  Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Video}">
                            <UniformGrid Columns="3" >
                                <CheckBox x:Name="CheckBoxTextToVideo" Content="TextToVideo" />
                                <CheckBox x:Name="CheckBoxImageToVideo" Content="ImageToVideo" />
                                <CheckBox x:Name="CheckBoxVideoToVideo" Content="VideoToVideo" />
                            </UniformGrid>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Top"  Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}">
                            <UniformGrid Columns="3" >
                                <CheckBox x:Name="CheckBoxTextToAudio" Content="TextToAudio" />
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!--View Filters-->
                <GroupBox DockPanel.Dock="Top" Header="View Filter" Margin="4,0,0,0">
                    <Grid Margin="4">
                        <StackPanel VerticalAlignment="Top"  Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Image}">
                            <UniformGrid Columns="3" >
                                <CheckBox x:Name="CheckBoxViewTextToImage" Content="TextToImage" />
                                <CheckBox x:Name="CheckBoxViewImageToImage" Content="ImageToImage" />
                                <CheckBox x:Name="CheckBoxViewImageEdit" Content="ImageEdit" />
                                <CheckBox x:Name="CheckBoxViewImageInpaint" Content="ImageInpaint" />
                                <CheckBox x:Name="CheckBoxViewPaintToImage" Content="PaintToImage" />
                                <CheckBox x:Name="CheckBoxViewFrameToFrame" Content="FrameToFrame" />
                            </UniformGrid>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Top"  Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Video}">
                            <UniformGrid Columns="3" >
                                <CheckBox x:Name="CheckBoxViewTextToVideo" Content="TextToVideo" />
                                <CheckBox x:Name="CheckBoxViewImageToVideo" Content="ImageToVideo" />
                                <CheckBox x:Name="CheckBoxViewVideoToVideo" Content="VideoToVideo" />
                            </UniformGrid>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Top"  Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}">
                            <UniformGrid Columns="3" >
                                <CheckBox x:Name="CheckBoxViewTextToMusic" Content="TextToMusic" />
                                <CheckBox x:Name="CheckBoxViewTextToAudio" Content="TextToAudio" />
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </GroupBox>

            </UniformGrid>


            <UniformGrid Rows="1" Margin="0,6,0,0">

                <!--Memory Settings-->
                <GroupBox Header="Memory Profile" Margin="0,0,4,0">
                    <StackPanel Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="Original Model Data Type" Style="{StaticResource FieldTextBlockStyle}"/>
                            <ComboBox ItemsSource="{Binding DataTypes}" SelectedItem="{Binding DiffusionModel.BaseType}" />
                        </StackPanel>

                        <TextBlock Text="Memory Modes" Style="{StaticResource FieldTextBlockStyle}" Margin="0,10,0,0"/>
                        <UniformGrid Columns="4" >
                            <TextBlock Text="Quality" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBlock Text="Low" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBlock Text="Medium" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBlock Text="High" Style="{StaticResource FieldTextBlockStyle}" />
                        </UniformGrid>

                        <ItemsControl ItemsSource="{Binding DiffusionModel.MemoryProfile}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <UniformGrid Columns="4">
                                        <TextBlock Text="{Binding QualityMode}" Margin="0,3,0,0"/>
                                        <TextBox  Text="{Binding MemoryModes[0], UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox  Text="{Binding MemoryModes[1], UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox  Text="{Binding MemoryModes[2], UpdateSourceTrigger=PropertyChanged}" />
                                    </UniformGrid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <!--Resolution Settings-->
                <GroupBox Header="Resolutions" Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource InverseEnumToVisibilityConverter}, ConverterParameter=Audio}" Margin="4,0,4,0">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top">
                            <Button DockPanel.Dock="Right" Command="{Binding AddSizeCommand}" Height="23" Width="40" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                                <CommonControls:FontAwesome Icon="2b" IconStyle="Light" Color="{StaticResource SuccessColour}"/>
                            </Button>
                            <UniformGrid Columns="3">
                                <StackPanel Margin="0,0,1,0">
                                    <TextBlock Text="Width" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <TextBox Text="{Binding SelectedSize.Width, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel  Margin="1,0,0,0">
                                    <TextBlock Text="Height" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <TextBox  Text="{Binding SelectedSize.Height, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom">
                                    <CheckBox Content="Default" IsChecked="{Binding SelectedSize.IsDefault, UpdateSourceTrigger=PropertyChanged}" Margin="3,0,0,3"/>
                                </StackPanel>
                            </UniformGrid>
                        </DockPanel>
                        <ListBox ItemsSource="{Binding Sizes}" SelectedItem="{Binding SelectedSize}" ItemContainerStyle="{StaticResource TransparentListBoxItem}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,3,0,0" Background="Transparent">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True"  />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource ButtonBackgroundDisabled}" Margin="2">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Command="{Binding RemoveSizeCommand, RelativeSource={RelativeSource AncestorType={x:Type local:DiffusionModelDialog}}}" CommandParameter="{Binding}" Style="{StaticResource TransparentButton}">
                                                <CommonControls:FontAwesome Icon="f00d" Color="{StaticResource DangerColour}" />
                                            </Button>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,2,0">
                                                <TextBlock Text="{Binding}"/>
                                                <TextBlock Text=" (default)" Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}" FontSize="9" FontStyle="Italic" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </GroupBox>


                <!--Default Settings-->
                <GroupBox Header="Default Options" Margin="4,0,0,0">
                    <DockPanel>

                        <!--General Top-->
                        <StackPanel DockPanel.Dock="Top">
                            <UniformGrid Columns="2">
                                <StackPanel>
                                    <TextBlock Text="Scheduler" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <ComboBox ItemsSource="{Binding Schedulers}" SelectedValue="{Binding DiffusionModel.DefaultOptions.Scheduler}" SelectedValuePath="Scheduler" DisplayMemberPath="Scheduler"/>
                                </StackPanel>
                            </UniformGrid>
                            <UniformGrid Columns="3">
                                <StackPanel>
                                    <TextBlock Text="Steps" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <TextBox Text="{Binding DiffusionModel.DefaultOptions.Steps, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Steps2" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <TextBox Text="{Binding DiffusionModel.DefaultOptions.Steps2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Guidance (CFG)" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:FloatBox FloatValue="{Binding DiffusionModel.DefaultOptions.GuidanceScale, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Guidance (Model)" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:FloatBox FloatValue="{Binding DiffusionModel.DefaultOptions.GuidanceScale2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Strength" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <TextBox Text="{Binding DiffusionModel.DefaultOptions.Strength, UpdateSourceTrigger=PropertyChanged}"  />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="NoiseCondition" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <TextBox Text="{Binding DiffusionModel.DefaultOptions.NoiseCondition, UpdateSourceTrigger=PropertyChanged}"  />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>


                        <!--General Bottom-->
                        <DockPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                            <StackPanel DockPanel.Dock="Right">
                                <TextBlock Text="Access Token" Style="{StaticResource FieldTextBlockStyle}"/>
                                <ComboBox ItemsSource="{Binding AccessTokens}" SelectedValue="{Binding DiffusionModel.AccessToken}" SelectedValuePath="Value" DisplayMemberPath="Name" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Repository Link" Style="{StaticResource FieldTextBlockStyle}"/>
                                <TextBox Text="{Binding DiffusionModel.Link, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </DockPanel>

                        <Grid>

                            <!--Image-->
                            <Grid Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Image}">
                                <StackPanel Margin="0,6,0,0">
                                    <UniformGrid Columns="2">
                                        <CheckBox Content="IsVaeSlicingEnabled" IsChecked="{Binding DiffusionModel.DefaultOptions.IsVaeSlicingEnabled}"/>
                                        <CheckBox Content="IsVaeTilingEnabled" IsChecked="{Binding DiffusionModel.DefaultOptions.IsVaeTilingEnabled}"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>

                            <!--Video-->
                            <Grid Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Video}">
                                <StackPanel>
                                    <UniformGrid Columns="3">
                                        <StackPanel>
                                            <TextBlock Text="FrameRate" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.FrameRate, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Channels" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.Channels, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="SampleRate" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.SampleRate, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Frames" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.Frames, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="FrameChunk" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.FrameChunk, UpdateSourceTrigger=PropertyChanged}"  />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="FrameChunkOverlap" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.FrameChunkOverlap, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <StackPanel>
                                        <TextBlock Text="Frame Options" Style="{StaticResource FieldTextBlockStyle}"/>
                                        <TextBox Text="{Binding FrameOptions, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <UniformGrid Columns="2" Margin="0,6,0,0">
                                        <CheckBox Content="IsVaeSlicingEnabled" IsChecked="{Binding DiffusionModel.DefaultOptions.IsVaeSlicingEnabled}"/>
                                        <CheckBox Content="IsVaeTilingEnabled" IsChecked="{Binding DiffusionModel.DefaultOptions.IsVaeTilingEnabled}"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>

                            <!--Audio-->
                            <Grid Visibility="{Binding DiffusionModel.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}">
                                <StackPanel>
                                    <UniformGrid Columns="3">
                                        <StackPanel>
                                            <TextBlock Text="SampleRate" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.SampleRate, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Channels" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.Channels, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="MaxLength" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.MaxLength, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="MaxLength2" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding DiffusionModel.DefaultOptions.MaxLength2, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>

                        </Grid>
                    </DockPanel>
                </GroupBox>

            </UniformGrid>







        </StackPanel>

        <!--Checkpoint Settings-->
        <Grid Margin="0,10,0,0" >
            <Controls:DiffusionCheckpointControl Settings="{Binding Settings}" Checkpoint="{Binding CheckpointModel}" Backend="{Binding DiffusionModel.Backend}"/>
        </Grid>
    </DockPanel>
</CommonControls:DialogControl>