<CommonControls:DialogControl x:Class="Amuse.App.Dialogs.QuestionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Amuse.App.Dialogs"
        xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
        mc:Ignorable="d"
        MinWidth="500"
        MaxWidth="500"
        x:Name="UI"
        Icon="/Images/Icon.ico"
        Style="{StaticResource {x:Type CommonControls:DialogControl}}">
    <DockPanel DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:QuestionDialog}}}" Margin="15, 15, 15, 10">

        <!--Save / Cancel-->
        <Grid DockPanel.Dock="Bottom"  Margin="0,15,0,0">
            <UniformGrid Columns="2" Height="30" HorizontalAlignment="Right">
                <Button Content="{Binding ButtonTextSave}" Command="{Binding SaveCommand}" Width="100" IsDefault="True" />
                <Button Content="{Binding ButtonTextCancel}" Command="{Binding CancelCommand}" Width="100"/>
            </UniformGrid>
        </Grid>

        <DockPanel>
            <CommonControls:FontAwesome DockPanel.Dock="Left" Size="50" Margin="0,5,0,20" Icon="f059" IconStyle="Light" Color="{StaticResource InfoColour}" />
            <StackPanel Margin="20,2,0,0" >

                <!--Title-->
                <Grid HorizontalAlignment="Left" TextBlock.FontSize="16">
                    <TextBlock Text="{Binding MessageTitle}"/>
                </Grid>

                <!--Message-->
                <Grid HorizontalAlignment="Left" Margin="0,3,0,0" TextBlock.FontStyle="Italic" TextBlock.FontSize="13" Opacity=".8">
                    <TextBlock Text="{Binding MessageBody}" TextWrapping="Wrap" />
                </Grid>

            </StackPanel>
        </DockPanel>

    </DockPanel>
</CommonControls:DialogControl>