<CommonControls:DialogControl x:Class="Amuse.App.Dialogs.UpscaleModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Amuse.App.Dialogs"
        xmlns:Controls="clr-namespace:Amuse.App.Controls"
        xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
        MinWidth="800"
        MaxWidth="800"
        Title="Upscale Model"
        Icon="/Images/Icon.ico"
        Style="{StaticResource {x:Type CommonControls:DialogControl}}">
    <DockPanel DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:UpscaleModelDialog}}}" Margin="15, 15, 15, 10">

        <!--Save/Cancel/Errors-->
        <DockPanel DockPanel.Dock="Bottom" Height="30" Margin="0,15,0,0">
            <UniformGrid DockPanel.Dock="Right" Columns="2" >
                <Button Content="Save" Command="{Binding SaveCommand}" Width="100" IsDefault="True"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </UniformGrid>
            <ItemsControl ItemsSource="{Binding Errors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="IndianRed" TextWrapping="Wrap" FontSize="11"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>

        <!--Main Content-->
        <StackPanel>

            <!--Model Settings-->
            <GroupBox Header="Settings" Padding="4">
                <StackPanel>
                    <UniformGrid  Rows="1">
                        <StackPanel Margin="0,0,2,0">
                            <TextBlock Text="Backend" Style="{StaticResource FieldTextBlockStyle}"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource BackendType}}" SelectedItem="{Binding UpscaleModel.Backend}" IsEnabled="False" Style="{StaticResource EnumComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0,2,0">
                            <TextBlock Text="Pipeline" Style="{StaticResource FieldTextBlockStyle}"/>
                            <ComboBox ItemsSource="{Binding Settings.Pipelines}" SelectedItem="{Binding UpscaleModel.Pipeline}"  IsEnabled="False" Style="{StaticResource EnumComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0,2,0">
                            <TextBlock Text="Name" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBox Text="{Binding UpscaleModel.Name, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </UniformGrid>
                    <UniformGrid Columns="4">
                        <StackPanel Margin="0,0,2,0">
                            <TextBlock Text="Scale Factor" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBox Text="{Binding UpscaleModel.ScaleFactor, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="2,0,2,0">
                            <TextBlock Text="Sample Size" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBox Text="{Binding UpscaleModel.SampleSize, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Margin="2,0,2,0">
                            <TextBlock Text="Input Normalization" Style="{StaticResource FieldTextBlockStyle}"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource NormalizationType}}" SelectedItem="{Binding UpscaleModel.Normalization}" SelectedIndex="0" Style="{StaticResource EnumComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="2,0,0,0">
                            <TextBlock Text="Output Normalization" Style="{StaticResource FieldTextBlockStyle}"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource NormalizationType}}" SelectedItem="{Binding UpscaleModel.OutputNormalization}" SelectedIndex="0" Style="{StaticResource EnumComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,2,0">
                            <TextBlock Text="MemorySize" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBox Text="{Binding UpscaleModel.MemorySize, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <!--DefaultOptions-->
                        <StackPanel IsEnabled="{Binding UpscaleModel.DefaultOptions.IsTileEnabled}" Margin="2,0,2,0">
                            <TextBlock Text="Tile Size" Style="{StaticResource FieldTextBlockStyle}" />
                            <TextBox Text="{Binding UpscaleModel.DefaultOptions.TileSize}" />
                        </StackPanel>
                        <StackPanel IsEnabled="{Binding UpscaleModel.DefaultOptions.IsTileEnabled}" Margin="2,0,2,0">
                            <TextBlock Text="Tile Overlap" Style="{StaticResource FieldTextBlockStyle}" />
                            <TextBox Text="{Binding UpscaleModel.DefaultOptions.TileOverlap}" />
                        </StackPanel>
                        <StackPanel Margin="2,0,0,0">
                            <CheckBox Content="Enable Tiling" IsChecked="{Binding UpscaleModel.DefaultOptions.IsTileEnabled}" Margin="0,19,0,0"/>
                        </StackPanel>
                    </UniformGrid>

                    <StackPanel Margin="0,2,0,0">
                        <TextBlock Text="Model Link" Style="{StaticResource FieldTextBlockStyle}"/>
                        <TextBox Text="{Binding UpscaleModel.Link, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!--Checkpoint Settings-->
            <GroupBox Header="{Binding UpscaleModel.Checkpoint.Name}" Margin="0,10,0,0" Height="160">
                <Controls:CheckpointControl Settings="{Binding Settings}" Checkpoint="{Binding UpscaleModel.Checkpoint}" Backend="{Binding UpscaleModel.Backend}" SupportedTypes="{Binding CheckpointTypes, Mode=OneWay}"/>
            </GroupBox>

        </StackPanel>
    </DockPanel>
</CommonControls:DialogControl>