                                    <Run Text="{Binding Options.VoiceStyle}" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Speed" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                    <Run Text="{Binding  Options.Speed}" />
                                    <Run Text="x" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Duration" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                    <Run Text="{Binding Duration, FallbackValue=00:00:00, StringFormat={}mm\\:ss\\.ff}" />
                                    <Run Text="ms" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Seed" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                    <Run Text="{Binding Options.Seed}" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Steps" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                    <Run Text="{Binding Options.Steps}" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Sample Rate" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                    <Run Text="{Binding SampleRate}" />
                                    <Run Text="hz" />
                                </TextBlock>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Margin="0,6,0,0" >
                            <TextBlock Text="Created" Style="{StaticResource FieldTextBlockStyle}" />
                            <TextBlock Text="{Binding Timestamp}" />
                        </StackPanel>
                        <UniformGrid Columns="2" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding MediaType, StringFormat={}{0} Path}" Style="{StaticResource FieldTextBlockStyle}" />
                                <CommonControls:HyperlinkControl Label="{Binding MediaPath, Converter={StaticResource FullPathToFileNameConverter}}" Link="{Binding MediaPath, Converter={StaticResource FullPathToFolderConverter}}" IsUnderlineEnabled="False" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Info Path" Style="{StaticResource FieldTextBlockStyle}" />
                                <CommonControls:HyperlinkControl Label="{Binding FilePath, Converter={StaticResource FullPathToFileNameConverter}}" Link="{Binding FilePath}" IsUnderlineEnabled="False" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </DockPanel>
            </DataTemplate>


            <DataTemplate DataType="{x:Type Common:TextHistory}">
                <DockPanel Margin="10,0,0,0">
                    <TextBlock DockPanel.Dock="Top" Text="{Binding MediaType, StringFormat={}Generated {0}}" FontSize="20"/>
                    <StackPanel>
                        <Separator Opacity=".7"/>
                        <UniformGrid Columns="3" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="Length" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                    <Run Text="{Binding InputLength}" />
                                </TextBlock>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Margin="0,6,0,0" >
                            <TextBlock Text="Created" Style="{StaticResource FieldTextBlockStyle}" />
                            <TextBlock Text="{Binding Timestamp}" />
                        </StackPanel>
                        <UniformGrid Columns="2" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding MediaType, StringFormat={}{0} Path}" Style="{StaticResource FieldTextBlockStyle}" />
                                <CommonControls:HyperlinkControl Label="{Binding MediaPath, Converter={StaticResource FullPathToFileNameConverter}}" Link="{Binding MediaPath, Converter={StaticResource FullPathToFolderConverter}}" IsUnderlineEnabled="False" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Info Path" Style="{StaticResource FieldTextBlockStyle}" />
                                <CommonControls:HyperlinkControl Label="{Binding FilePath, Converter={StaticResource FullPathToFileNameConverter}}" Link="{Binding FilePath}" IsUnderlineEnabled="False" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </DockPanel>
            </DataTemplate>


            <DataTemplate DataType="{x:Type Common:ComposeHistory}">
                <DockPanel Margin="10,0,0,0">
                    <TextBlock DockPanel.Dock="Top" Text="{Binding MediaType, StringFormat={}Composed {0}}" FontSize="20"/>
                    <StackPanel>
                        <Separator Opacity=".7"/>

                        <UniformGrid Columns="3" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding MediaType, StringFormat={}{0} Size}" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                    <Run Text="{Binding Width}" />
                                    <Run Text="x" />
                                    <Run Text="{Binding Height}" />
                                    <Run Text="px" />
                                </TextBlock>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Margin="0,6,0,0" >
                            <TextBlock Text="Created" Style="{StaticResource FieldTextBlockStyle}" />
                            <TextBlock Text="{Binding Timestamp}" />
                        </StackPanel>
                        <UniformGrid Columns="2" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding MediaType, StringFormat={}{0} Path}" Style="{StaticResource FieldTextBlockStyle}" />
                                <CommonControls:HyperlinkControl Label="{Binding MediaPath, Converter={StaticResource FullPathToFileNameConverter}}" Link="{Binding MediaPath, Converter={StaticResource FullPathToFolderConverter}}" IsUnderlineEnabled="False" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Info Path" Style="{StaticResource FieldTextBlockStyle}" />
                                <CommonControls:HyperlinkControl Label="{Binding FilePath, Converter={StaticResource FullPathToFileNameConverter}}" Link="{Binding FilePath}" IsUnderlineEnabled="False" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </DockPanel>
            </DataTemplate>


            <DataTemplate DataType="{x:Type Common:RecentHistory}">
                <DockPanel Margin="10,0,0,0">
                    <TextBlock DockPanel.Dock="Top" Text="{Binding MediaType, StringFormat={}Recent {0}}" FontSize="20"/>
                    <StackPanel>
                        <Separator Opacity=".7"/>
                        <UniformGrid Columns="3" Margin="0,3,0,0">
                            <StackPanel Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Image|Video}">
                                <TextBlock Text="{Binding MediaType, StringFormat={}{0} Size}" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                   <Run Text="{Binding Width}" />
                                   <Run Text="x" />
                                   <Run Text="{Binding Height}" />
                                   <Run Text="px" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Video}">
                                <TextBlock Text="Frame Rate" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock>
                                    <Run Text="{Binding FrameRate}" />
                                    <Run Text="fps" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Video}">
                                <TextBlock Text="Frames" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock Text="{Binding FrameCount}" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}">
                                <TextBlock Text="Sample Rate" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBlock Text="{Binding SampleRate}" />
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Margin="0,6,0,0" >
                            <TextBlock Text="Created" Style="{StaticResource FieldTextBlockStyle}" />
                            <TextBlock Text="{Binding Timestamp}" />
                        </StackPanel>
                        <UniformGrid Columns="2" Margin="0,6,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding MediaType, StringFormat={}{0} Path}" Style="{StaticResource FieldTextBlockStyle}" />
                                <CommonControls:HyperlinkControl Label="{Binding MediaPath, Converter={StaticResource FullPathToFileNameConverter}}" Link="{Binding MediaPath, Converter={StaticResource FullPathToFolderConverter}}" IsUnderlineEnabled="False" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Info Path" Style="{StaticResource FieldTextBlockStyle}" />
                                <CommonControls:HyperlinkControl Label="{Binding FilePath, Converter={StaticResource FullPathToFileNameConverter}}" Link="{Binding FilePath}" IsUnderlineEnabled="False" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </DockPanel>
            </DataTemplate>


            <Style x:Key="SettingsListBoxItem" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0"/>
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{StaticResource ControlBrightDefaultBorderBrush }" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch"></Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border Name="Border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" Margin="{TemplateBinding Padding}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger  Property="IsSelected" Value="True" >
                        <Setter Property="Background" Value="{StaticResource ControlMouseOverBackground}" />
                        <Setter Property="BorderBrush" Value="{StaticResource AccentColour2}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
