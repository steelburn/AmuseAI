<Views:ViewBase x:Class="Amuse.App.Views.GalleryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    
    xmlns:local="clr-namespace:Amuse.App.Views"
    xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
    xmlns:Controls="clr-namespace:Amuse.App.Controls"
    xmlns:Common="clr-namespace:Amuse.App.Common"
    xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:GalleryView}}}" >

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="1*" MinWidth="600"/>
        </Grid.ColumnDefinitions>

        <!--Collection-->
        <Grid Grid.Column="0"  Margin="10,10,5,10">

            <DockPanel>

                <!--Top Panel-->
                <Border DockPanel.Dock="Top" BorderBrush="{StaticResource DefaultBorderColor}" BorderThickness="1" Padding="4,0,4,4" >
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right">
                            <TextBlock Text="" Style="{StaticResource FieldTextBlockStyle}"/>
                            <CommonControls:IconButton  Icon="f00d" IconColor="{StaticResource DangerColour}" Text="Clear" Command="{Binding RemoveFiltersCommand}" Width="70" Height="22" FontSize="11"/>
                        </StackPanel>
                        <UniformGrid Rows="1">
                            <StackPanel>
                                <TextBlock Text="Search" Style="{StaticResource FieldTextBlockStyle}"/>
                                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Media Type" Style="{StaticResource FieldTextBlockStyle}"/>
                                <CommonControls:NullableComboBox ItemsSource="{Binding Source={StaticResource MediaType}}" SelectedItem="{Binding FilterMediaType}" NullPrefix="All Media" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Model" Style="{StaticResource FieldTextBlockStyle}"/>
                                <ComboBox ItemsSource="{Binding FilterModelNames}" SelectedItem="{Binding FilterModelName}"  />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Process Type" Style="{StaticResource FieldTextBlockStyle}"/>
                                <CommonControls:NullableComboBox ItemsSource="{Binding FilterProcessTypes}" SelectedItem="{Binding FilterProcessType}" NullPrefix="All Processes" />
                            </StackPanel>
                        </UniformGrid>
                    </DockPanel>
                </Border>

                <!--Bottom Panel-->
                <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource DefaultBorderColor}" BorderThickness="1" Padding="4,0,4,0" >
                    <DockPanel Height="30">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Items: " />
                            <TextBlock Text="{Binding HistoryCollection.Count}" />
                            <TextBlock Text=" / " />
                            <TextBlock Text="{Binding HistoryCollection.SourceCollection.Count}" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                            <CommonControls:IconButton  Icon="f2ed" IconSize="13" IconColor="{StaticResource DangerColour}" Text="{Binding HistoryCollection.Count, StringFormat={}Delete {0} Items}" Command="{Binding DeleteItemsCommand}" Width="150" Height="26" />
                        </StackPanel>
                        <TextBlock />
                    </DockPanel>
                </Border>

                <!--Middle-->
                <Border BorderBrush="{StaticResource DefaultBorderColor}" BorderThickness="1" Margin="0,4">
                    <ScrollViewer PanningMode="VerticalOnly" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"  >
                        <Grid>
                            <ListBox x:Name="ListBoxControl" 
                                Padding="0"
                                VerticalAlignment="Top"
                                BorderThickness="0,0,0,0"
                                Background="{StaticResource TransparentBrush}"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled" 
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                IsSynchronizedWithCurrentItem="True"
                                ItemsSource="{Binding HistoryCollection}" 
                                VirtualizingPanel.IsVirtualizing="True"
                                VirtualizingPanel.VirtualizationMode="Recycling"
                                SelectionChanged="ListBoxControl_SelectionChanged"
                                SelectedItem="{Binding SelectedItem, Mode=OneWayToSource}">

                                <!--DataTemplates-->
                                <ListBox.Resources>

                                    <DataTemplate DataType="{x:Type Common:DiffusionHistory}">
                                        <DockPanel Margin="3">
                                            <Grid DockPanel.Dock="Top">
                                                <Grid Width="120" Height="120" Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}">
                                                    <CommonControls:FontAwesome Icon="f001" IconStyle="Solid" Size="96" Color="{StaticResource DefaultForeground}" Opacity=".2" />
                                                </Grid>
                                                <Grid Width="120" Height="120" Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Text}">
                                                    <CommonControls:FontAwesome Icon="f894" IconStyle="Solid" Size="96" Color="{StaticResource DefaultForeground}" Opacity=".2" />
                                                </Grid>
                                                <CommonControls:TransparentImageElement 
                                                    Height="120" 
                                                    Stretch="Uniform" 
                                                    DecodePixelHeight="80"
                                                    UriSource="{Binding ThumbPath, Converter={StaticResource StringToUriConverter}}" />
                                            </Grid>
                                            <Grid Margin="0,3,0,0">
                                                <StackPanel Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Image|Video}">
                                                    <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                        <Run Text="{Binding Width}" />
                                                        <Run Text="x" />
                                                        <Run Text="{Binding Height}" />
                                                        <LineBreak/>
                                                        <Run Text="{Binding Source}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}">
                                                    <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                        <Run Text="{Binding Duration, FallbackValue=00:00:00, StringFormat={}mm\\:ss\\.ff}" />
                                                        <LineBreak/>
                                                        <Run Text="{Binding Source}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Text}">
                                                    <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                        <Run Text="{Binding Options.Task}" />
                                                        <LineBreak/>
                                                        <Run Text="{Binding Source}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </DockPanel>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type Common:ExtractHistory}">
                                        <DockPanel Margin="3">
                                            <Grid DockPanel.Dock="Top">
                                                <CommonControls:TransparentImageElement 
                                                    Height="120" 
                                                    Stretch="Uniform" 
                                                    DecodePixelHeight="80"
                                                    UriSource="{Binding ThumbPath, Converter={StaticResource StringToUriConverter}}" />
                                            </Grid>
                                            <StackPanel Margin="0,3,0,0">
                                                <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                    <Run Text="{Binding Width}" />
                                                    <Run Text="x" />
                                                    <Run Text="{Binding Height}" />
                                                    <LineBreak/>
                                                    <Run Text="{Binding Source}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type Common:UpscaleHistory}">
                                        <DockPanel Margin="3">
                                            <Grid DockPanel.Dock="Top">
                                                <CommonControls:TransparentImageElement 
                                                    Height="120" 
                                                    Stretch="Uniform" 
                                                    DecodePixelHeight="80"
                                                    UriSource="{Binding ThumbPath, Converter={StaticResource StringToUriConverter}}" />
                                            </Grid>
                                            <StackPanel Margin="0,3,0,0">
                                                <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                    <Run Text="{Binding Width}" />
                                                    <Run Text="x" />
                                                    <Run Text="{Binding Height}" />
                                                    <LineBreak/>
                                                    <Run Text="{Binding Source}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type Common:InterpolateHistory}">
                                        <DockPanel Margin="3">
                                            <Grid DockPanel.Dock="Top">
                                                <CommonControls:TransparentImageElement 
                                                    Height="120" 
                                                    Stretch="Uniform" 
                                                    DecodePixelHeight="80"
                                                    UriSource="{Binding ThumbPath, Converter={StaticResource StringToUriConverter}}" />
                                            </Grid>
                                            <StackPanel Margin="0,3,0,0">
                                                <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                    <Run Text="{Binding Width}" />
                                                    <Run Text="x" />
                                                    <Run Text="{Binding Height}" />
                                                    <LineBreak/>
                                                    <Run Text="{Binding Source}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type Common:AudioHistory}">
                                        <DockPanel Margin="3" Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}">
                                            <Grid DockPanel.Dock="Top">
                                                <CommonControls:FontAwesome Icon="f001" IconStyle="Solid" Size="96" Color="{StaticResource DefaultForeground}" Opacity=".2" Width="120" Height="120" />
                                            </Grid>
                                            <StackPanel Margin="0,3,0,0">
                                                <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                    <Run Text="{Binding Duration, FallbackValue=00:00:00, StringFormat={}mm\\:ss\\.ff}" />
                                                    <LineBreak/>
                                                    <Run Text="{Binding Source}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type Common:TextHistory}">
                                        <DockPanel Margin="3" Visibility="{Binding MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Text}">
                                            <Grid DockPanel.Dock="Top">
                                                <CommonControls:FontAwesome Icon="f894" IconStyle="Solid" Size="96" Color="{StaticResource DefaultForeground}" Opacity=".2" Width="120" Height="120" />
                                            </Grid>
                                            <StackPanel Margin="0,3,0,0">
                                                <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                    <Run Text="{Binding InputLength}" />
                                                    <LineBreak/>
                                                    <Run Text="{Binding Source}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type Common:ComposeHistory}">
                                        <DockPanel Margin="3">
                                            <Grid DockPanel.Dock="Top">
                                                <CommonControls:TransparentImageElement 
                                                    Height="120" 
                                                    Stretch="Uniform" 
                                                    DecodePixelHeight="80"
                                                    UriSource="{Binding ThumbPath, Converter={StaticResource StringToUriConverter}}" />
                                            </Grid>
                                            <StackPanel Margin="0,3,0,0">
                                                <TextBlock TextAlignment="Center" LineHeight="14" LineStackingStrategy="BlockLineHeight">
                                                    <Run Text="{Binding Width}" />
                                                    <Run Text="x" />
                                                    <Run Text="{Binding Height}" />
                                                    <LineBreak/>
                                                    <Run Text="{Binding Source}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>

                                </ListBox.Resources>

                                <!--ItemContainerStyle-->
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,1,3,1"/>
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush" Value="{StaticResource ContainerBorder}" />
                                        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                    <Border Name="Border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                                        <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" Margin="{TemplateBinding Padding}" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <!--ItemsPanel-->
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <CommonControls:UniformWrapPanel  IsItemsHost="True" SnapsToDevicePixels="True" VerticalAlignment="Top" >
                                            <CommonControls:UniformWrapPanel.Style>
                                                <Style TargetType="{x:Type CommonControls:UniformWrapPanel}" >
                                                    <Setter Property="MinItemWidth" Value="140"/>
                                                    <Setter Property="MaxItemWidth" Value="200"/>
                                                </Style>
                                            </CommonControls:UniformWrapPanel.Style>
                                        </CommonControls:UniformWrapPanel>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                            </ListBox>

                            <Grid Visibility="{Binding HistoryCollection.Count, Converter={StaticResource LessOrEqualThanToVisibilityConverter}, ConverterParameter=0}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="No Items Found." FontSize="18" Opacity="0.6"/>
                                </StackPanel>
                            </Grid>

                        </Grid>
                    </ScrollViewer>
                </Border>
            </DockPanel>

        </Grid>

        <!--GridSplitter-->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />

        <!--Information-->
        <Border Grid.Column="2" BorderBrush="{StaticResource DefaultBorderColor}" BorderThickness="1" Margin="5, 10, 10, 10">
            <Grid>
                <Grid Visibility="{Binding SelectedItem, Converter={StaticResource NullVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" MinHeight="400"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!--Image/Video-->
                    <Grid Grid.Row="0" >
                        <Grid Margin="10">
                            <CommonControls:ImageElement 
                                IsLoadEnabled="False" 
                                IsLoadOverlayEnabled="False" 
                                IsSaveOverlayEnabled="False" 
                                IsRemoveEnabled="False"
                                IsContextMenuEnabled="True"
                                Source="{Binding CurrentImage}"
                                Progress="{Binding Progress}"
                                Visibility="{Binding SelectedItem.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Image}"/>
                            <CommonControls:VideoStreamElement
                                IsReplayEnabled="True"
                                IsAutoPlayEnabled="False"
                                IsLoadEnabled="False"
                                IsLoadOverlayEnabled="False" 
                                IsSaveEnabled="False" 
                                IsRemoveEnabled="False"
                                IsFrameViewerEnabled="True"
                                IsInputEnabled="True"
                                IsContextMenuEnabled="True"
                                Source="{Binding CurrentVideoStream}" 
                                Progress="{Binding Progress}"
                                Volume="{Binding Settings.VolumeOutput, Mode=TwoWay}"
                                IsVolumeMute="{Binding Settings.IsVolumeOutputMute, Mode=TwoWay}"
                                Visibility="{Binding SelectedItem.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Video}"/>
                            <CommonControls:AudioStreamElement
                                IsReplayEnabled="True"
                                IsAutoPlayEnabled="False"
                                IsLoadEnabled="False"
                                IsSaveEnabled="True"
                                IsRemoveEnabled="False"
                                IsInputEnabled="True"
                                IsContextMenuEnabled="True"
                                Source="{Binding CurrentAudioStream}"
                                Volume="{Binding Settings.VolumeOutput, Mode=TwoWay}"
                                IsVolumeMute="{Binding Settings.IsVolumeOutputMute, Mode=TwoWay}"
                                Visibility="{Binding SelectedItem.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Audio}"/>

                            <CommonControls:TextElement 
                                IsReadOnly="True"
                                IsLoadEnabled="False"
                                IsRemoveEnabled="False"
                                TextSource="{Binding CurrentText, Mode=OneWay}"
                                Visibility="{Binding SelectedItem.MediaType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Text}"/>
                        </Grid>
                    </Grid>

                    <!--SelectedItem-->
                    <Grid Grid.Row="1" >
                        <ContentControl Content="{Binding SelectedItem}" Foreground="{StaticResource DefaultForeground}" Margin="0,0,0,20"/>
                    </Grid>

                    <DockPanel Grid.Row="2">
                        <CommonControls:IconButton  Icon="f2ed" Text="Delete Item" IconSize="13" IconColor="{StaticResource DangerColour}" Command="{Binding DeleteItemCommand}" CommandParameter="{Binding SelectedItem}" Width="150" Height="26" HorizontalAlignment="Right" Margin="4,2"/>
                    </DockPanel>
                </Grid>

                <Grid Visibility="{Binding SelectedItem, Converter={StaticResource InverseNullVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="No Information Found." FontSize="18" Opacity="0.6"/>
                    </StackPanel>
                </Grid>

            </Grid>

        </Border>

    </Grid>
</Views:ViewBase>
