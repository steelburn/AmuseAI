<Views:ViewBaseDiffusion x:Class="Amuse.App.Views.TextToAudioView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Amuse.App.Views"
    xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
    xmlns:Controls="clr-namespace:Amuse.App.Controls"
    xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:TextToAudioView}}}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="380"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="Auto" MaxWidth="330" />
            </Grid.ColumnDefinitions>

            <!--***Left Panel***-->
            <Grid Grid.Column="0">
                <Border Margin="4">
                    <DockPanel x:Name="LeftPanelContainer" Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">

                        <!--ModelControl-->
                        <Grid DockPanel.Dock="Top" IsEnabled="{Binding DiffusionService.IsLoading, Converter={StaticResource InverseBoolConverter}}">
                            <Grid IsEnabled="{Binding DiffusionService.IsExecuting, Converter={StaticResource InverseBoolConverter}}">
                                <Grid IsEnabled="{Binding IsAutomating, Converter={StaticResource InverseBoolConverter}}">
                                    <Controls:DiffusionModelControl
                                        x:Name="ModelControl"
                                        ViewType="TextToAudio"
                                        ProcessType="TextToAudio"
                                        IsLoraSupported="False"
                                        IsUpscalerSupported="False"
                                        IsExtractorSupported="False"
                                        IsControlNetSupported="False"
                                        Settings="{Binding Settings, Mode=OneWay}" 
                                        IsPipelineLoaded="{Binding IsPipelineLoaded, Mode=OneWay}"
                                        DownloadService="{Binding DownloadService, Mode=OneTime}"
                                        NavigationService="{Binding NavigationService, Mode=OneTime}"
                                        SelectionChanged="SelectedPipelineChanged"/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <DockPanel DockPanel.Dock="Bottom">

                            <!--Execute/Cancel-->
                            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="30" >
                                <DockPanel>
                                    <Button DockPanel.Dock="Left" Width="30" Command="{Binding StopCommand}" Visibility="{Binding DiffusionService.IsCanceling, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Immediately stops generation by closing the backend process." ToolTipService.InitialShowDelay="200">
                                        <CommonControls:FontAwesome Icon="f00d" Color="{StaticResource DangerColour}" />
                                    </Button>
                                    <Grid IsEnabled="{Binding DiffusionService.IsCanceling, Converter={StaticResource InverseBoolConverter}}">
                                        <Button Command="{Binding CancelCommand}" >
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Cancel" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DiffusionService.IsCanceling}" Value="True">
                                                            <Setter Property="Content" Value="Canceling" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DockPanel>
                                <Grid IsEnabled="{Binding IsSelectionValid, ElementName=ModelControl}">
                                    <Button Content="Generate" Command="{Binding ExecuteCommand}" Visibility="{Binding SelectedOption, ElementName=InputControl, Converter={StaticResource InverseEnumToVisibilityConverter}, ConverterParameter=Automation}"/>
                                    <Button Content="Automate" Command="{Binding ExecuteAutomationCommand}" Visibility="{Binding SelectedOption, ElementName=InputControl, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Automation}"/>
                                </Grid>
                            </UniformGrid>


                            <!--InputControl-->
                            <StackPanel >
                                <Controls:AudioDiffusionInputControl
                                    x:Name="InputControl"
                                    ViewType="TextToAudio"
                                    ProcessType="TextToAudio"
                                    Options="{Binding Options, Mode=OneWayToSource}"
                                    AutomationOptions="{Binding AutomationOptions, Mode=OneWayToSource}"
                                    AutomationProgress="{Binding AutomationProgress, Mode=OneWay}"
                                    Pipeline="{Binding CurrentPipeline, Mode=OneWay}" 
                                    IsExecuting="{Binding DiffusionService.IsExecuting, Mode=OneWay}"
                                    IsAutomating="{Binding IsAutomating, Mode=OneWay}"
                                    IsEnabled="{Binding IsPipelineLoaded}"/>
                            </StackPanel>

                        </DockPanel>
                    </DockPanel>
                </Border>
            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />


            <!--***Right Panel***-->
            <Grid Grid.Column="2" Grid.Row="0" >

                <!--Content-->
                <DockPanel>

                    <!--Statistics-->
                    <Controls:StatisticsControl 
                        DockPanel.Dock="Bottom"
                        Margin="14,0,14,8"
                        Statistics="{Binding Statistics}"
                        Progress="{Binding Progress}" />

                    <Border Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">
                        <DockPanel IsEnabled="{Binding DiffusionService.IsExecuting, Converter={StaticResource InverseBoolConverter}}">

                            <!--Output-->
                            <DockPanel DockPanel.Dock="Bottom" Margin="10,10,10,4">
                                <DockPanel Height="150">
                                    <TextBlock DockPanel.Dock="Top" Text="Audio Result" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:AudioStreamElement Source="{Binding ResultAudio, Mode=TwoWay}" IsLoadEnabled="False" IsInputEnabled="{Binding IsPipelineLoaded}" />
                                </DockPanel>
                            </DockPanel>

                            <!--Prompt-->
                            <Grid Margin="10,0,10,0" IsEnabled="{Binding IsPipelineLoaded}">
                                <DockPanel IsEnabled="{Binding IsAutomating, Converter={StaticResource InverseBoolConverter}}">
                                    <TextBlock DockPanel.Dock="Top" Text="Input Text" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:TextElement TextSource="{Binding SourceText}" IsSaveEnabled="False" AcceptsReturn="True" TextWrapping="Wrap"/>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
                </DockPanel>

            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />


            <!--Help/Information-->
            <Grid Grid.Column="4" Grid.Row="0" >



            </Grid>

        </Grid>
    </Grid>
</Views:ViewBaseDiffusion>
