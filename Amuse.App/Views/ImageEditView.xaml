<Views:ViewBaseDiffusion x:Class="Amuse.App.Views.ImageEditView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Amuse.App.Views"
    xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
    xmlns:Controls="clr-namespace:Amuse.App.Controls"
    xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ImageEditView}}}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="380"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>


            <!--***Left Panel***-->
            <Grid Grid.Column="0">
                <Border Margin="4">
                    <DockPanel x:Name="LeftPanelContainer" Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">

                        <!--ModelControl-->
                        <StackPanel DockPanel.Dock="Top" IsEnabled="{Binding DiffusionService.IsLoading, Converter={StaticResource InverseBoolConverter}}">
                            <Grid IsEnabled="{Binding DiffusionService.IsExecuting, Converter={StaticResource InverseBoolConverter}}">
                                <Controls:DiffusionModelControl
                                    x:Name="ModelControl"
                                    ViewType="ImageEdit"
                                    ProcessType="ImageEdit"
                                    IsLoraSupported="True"
                                    IsUpscalerSupported="True"
                                    Settings="{Binding Settings, Mode=OneWay}" 
                                    IsPipelineLoaded="{Binding IsPipelineLoaded, Mode=OneWay}"
                                    DownloadService="{Binding DownloadService, Mode=OneTime}"
                                    EnvironmentService="{Binding EnvironmentService, Mode=OneTime}"
                                    NavigationService="{Binding NavigationService, Mode=OneTime}"
                                    SelectionChanged="SelectedPipelineChanged"/>
                            </Grid>
                        </StackPanel>

                        <DockPanel DockPanel.Dock="Bottom" >

                            <!--Execute/Cancel-->
                            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="30" >
                                <DockPanel>
                                    <Button DockPanel.Dock="Left" Width="30" Command="{Binding StopCommand}" Visibility="{Binding DiffusionService.IsCanceling, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Immediately stops generation by closing the backend process." ToolTipService.InitialShowDelay="200">
                                        <CommonControls:FontAwesome Icon="f00d" Color="{StaticResource DangerColour}" />
                                    </Button>
                                    <Grid IsEnabled="{Binding DiffusionService.IsCanceling, Converter={StaticResource InverseBoolConverter}}">
                                        <Button Command="{Binding CancelCommand}" >
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Cancel" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DiffusionService.IsCanceling}" Value="True">
                                                            <Setter Property="Content" Value="Canceling" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DockPanel>
                                <Grid IsEnabled="{Binding IsSelectionValid, ElementName=ModelControl}">
                                    <Button Content="Generate" Command="{Binding ExecuteCommand}" />
                                </Grid>
                            </UniformGrid>

                            <!--InputControl-->
                            <Grid IsEnabled="{Binding DiffusionService.IsLoaded}">
                                <Controls:DiffusionInputControl 
                                    x:Name="InputControl"
                                    ProcessType="ImageEdit"
                                    Options="{Binding Options, Mode=OneWayToSource}"
                                    UpscaleOptions="{Binding UpscaleOptions, Mode=OneWayToSource}"
                                    Pipeline="{Binding CurrentPipeline}" 
                                    IsImageInputEnabled="True"
                                    IsControlNetEnabled="False"
                                    IsEnabled="{Binding CurrentPipeline, Converter={StaticResource InverseNullBooleanConverter}}"/>
                            </Grid>

                        </DockPanel>
                    </DockPanel>
                </Border>
            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />


            <!--***Right Panel***-->
            <Grid Grid.Column="2" Grid.Row="0" >

                <!--Content-->
                <DockPanel>

                    <!--Statistics-->
                    <Controls:StatisticsControl 
                        DockPanel.Dock="Bottom"
                        Margin="14,0,14,8"
                        Statistics="{Binding Statistics}"
                        Progress="{Binding Progress}" />

                    <Border Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">
                        <UniformGrid Columns="2">

                            <Grid Margin="10,10,10,2" IsEnabled="{Binding IsPipelineLoaded}">
                                <UniformGrid IsEnabled="{Binding DiffusionService.IsExecuting, Converter={StaticResource InverseBoolConverter}}">
                                    <Border >
                                        <CommonControls:ImageElement 
                                            CropWidth="{Binding Options.Width}"
                                            CropHeight="{Binding Options.Height}"
                                            SplitterVisibility="Auto"
                                            SplitterPosition="Source"
                                            SplitterDirection="LeftToRight"
                                            Source="{Binding SourceImage1, Mode=TwoWay}" 
                                            IsLoadEnabled="True" 
                                            IsSaveEnabled="False"
                                            IsLoadOverlayEnabled="False"/>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource ImageDropZoneStyle}">
                                                <Setter Property="Margin" Value="0"></Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl, Converter={StaticResource GreaterOrEqualThanToBooleanConverter}, ConverterParameter=2}" Value="True">
                                                        <Setter Property="Margin" Value="0,0,0,4"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl, Converter={StaticResource GreaterOrEqualThanToBooleanConverter}, ConverterParameter=3}" Value="True">
                                                        <Setter Property="Margin" Value="0,0,4,4"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border>
                                        <CommonControls:ImageElement 
                                            CropWidth="{Binding Options.Width}"
                                            CropHeight="{Binding Options.Height}"
                                            SplitterVisibility="Auto"
                                            SplitterPosition="Source"
                                            SplitterDirection="LeftToRight"
                                            Source="{Binding SourceImage2, Mode=TwoWay}" 
                                            IsLoadEnabled="True" 
                                            IsSaveEnabled="False"
                                            IsLoadOverlayEnabled="False"/>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource ImageDropZoneStyle}">
                                                <Setter Property="Margin" Value="0,0,0,0"/>
                                                <Setter Property="Visibility" Value="Collapsed"></Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl, Converter={StaticResource GreaterOrEqualThanToBooleanConverter}, ConverterParameter=2}" Value="True">
                                                        <Setter Property="Margin" Value="0,4,0,0"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl, Converter={StaticResource GreaterOrEqualThanToBooleanConverter}, ConverterParameter=3}" Value="True">
                                                        <Setter Property="Margin" Value="4,0,0,4"/>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border>
                                        <CommonControls:ImageElement 
                                            CropWidth="{Binding Options.Width}"
                                            CropHeight="{Binding Options.Height}"
                                            SplitterVisibility="Auto"
                                            SplitterPosition="Source"
                                            SplitterDirection="LeftToRight"
                                            Source="{Binding SourceImage3, Mode=TwoWay}" 
                                            IsLoadEnabled="True" 
                                            IsSaveEnabled="False"
                                            IsLoadOverlayEnabled="False"/>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource ImageDropZoneStyle}">
                                                <Setter Property="Margin" Value="0,4,4,0"/>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl, Converter={StaticResource GreaterOrEqualThanToBooleanConverter}, ConverterParameter=3}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border>
                                        <CommonControls:ImageElement 
                                            CropWidth="{Binding Options.Width}"
                                            CropHeight="{Binding Options.Height}"
                                            SplitterVisibility="Auto"
                                            SplitterPosition="Source"
                                            SplitterDirection="LeftToRight"
                                            Source="{Binding SourceImage4, Mode=TwoWay}" 
                                            IsLoadEnabled="True" 
                                            IsSaveEnabled="False"
                                            IsLoadOverlayEnabled="False"/>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource ImageDropZoneStyle}">
                                                <Setter Property="Margin" Value="4,4,0,0"/>
                                                <Setter Property="Visibility" Value="Collapsed"></Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl, Converter={StaticResource GreaterOrEqualThanToBooleanConverter}, ConverterParameter=4}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"></Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <UniformGrid.Style>
                                        <Style TargetType="{x:Type UniformGrid}">
                                            <Setter Property="Rows" Value="1"></Setter>
                                            <Setter Property="Columns" Value="1"></Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl}" Value="1">
                                                    <Setter Property="Rows" Value="1"></Setter>
                                                    <Setter Property="Columns" Value="1"></Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl}" Value="2">
                                                    <Setter Property="Rows" Value="2"></Setter>
                                                    <Setter Property="Columns" Value="1"></Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl}" Value="3">
                                                    <Setter Property="Rows" Value="2"></Setter>
                                                    <Setter Property="Columns" Value="2"></Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.InputImageCount, ElementName=InputControl}" Value="4">
                                                    <Setter Property="Rows" Value="2"></Setter>
                                                    <Setter Property="Columns" Value="2"></Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </UniformGrid.Style>
                                </UniformGrid>
                            </Grid>

                            <Grid Margin="10,10,10,2" >
                                <CommonControls:ImageElement 
                                    SplitterVisibility="Auto"
                                    SplitterPosition="Source"
                                    SplitterDirection="LeftToRight"
                                    Source="{Binding ResultImage, Mode=TwoWay}" 
                                    OverlaySource="{Binding CompareImage, Mode=TwoWay}" 
                                    IsLoadEnabled="False" 
                                    IsLoadOverlayEnabled="False"/>
                            </Grid>
                        </UniformGrid>
                    </Border>
                </DockPanel>

            </Grid>
        </Grid>

    </Grid>
</Views:ViewBaseDiffusion>
