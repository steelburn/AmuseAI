<Views:ViewBaseDiffusion x:Class="Amuse.App.Views.ImageToVideoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Amuse.App.Views"
    xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
    xmlns:Controls="clr-namespace:Amuse.App.Controls"
    xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ImageToVideoView}}, Mode=OneTime}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="380"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!--***Left Panel***-->
            <Grid Grid.Column="0">
                <Border Margin="4">
                    <DockPanel x:Name="LeftPanelContainer" Margin="4" IsEnabled="{Binding IsViewBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">

                        <!--ModelControl-->
                        <Grid DockPanel.Dock="Top" IsEnabled="{Binding DiffusionService.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                            <Grid IsEnabled="{Binding DiffusionService.IsExecuting, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                                <Grid IsEnabled="{Binding IsAutomating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                                    <Controls:DiffusionModelControl
                                        x:Name="ModelControl"
                                        ViewType="ImageToVideo"
                                        ProcessType="ImageToVideo"
                                        IsLoraSupported="True"
                                        IsUpscalerSupported="True"
                                        IsExtractorSupported="True"
                                        Settings="{Binding Settings, Mode=OneWay}" 
                                        IsPipelineLoaded="{Binding IsPipelineLoaded, Mode=OneWay}"
                                        DownloadService="{Binding DownloadService, Mode=OneTime}"
                                        NavigationService="{Binding NavigationService, Mode=OneTime}"
                                        SelectionChanged="SelectedPipelineChanged"/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <DockPanel DockPanel.Dock="Bottom">

                            <!--Execute/Cancel-->
                            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="30" >
                                <DockPanel>
                                    <Button DockPanel.Dock="Left" Width="30" Command="{Binding StopCommand, Mode=OneWay}" Visibility="{Binding DiffusionService.IsCanceling, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Immediately stops generation by closing the backend process." ToolTipService.InitialShowDelay="200">
                                        <CommonControls:FontAwesome Icon="f00d" Color="{StaticResource DangerColour}" />
                                    </Button>
                                    <Grid IsEnabled="{Binding DiffusionService.IsCanceling, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                                        <Button Command="{Binding CancelCommand, Mode=OneWay}" >
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Cancel" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DiffusionService.IsCanceling, Mode=OneWay}" Value="True">
                                                            <Setter Property="Content" Value="Canceling" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DockPanel>
                                <Grid IsEnabled="{Binding IsSelectionValid, ElementName=ModelControl}">
                                    <Button Content="Generate" Command="{Binding ExecuteCommand, Mode=OneWay}" Visibility="{Binding SelectedOption, Mode=OneWay, ElementName=InputControl, Converter={StaticResource InverseEnumToVisibilityConverter}, ConverterParameter=Automation}"/>
                                    <Button Content="Automate" Command="{Binding ExecuteAutomationCommand, Mode=OneWay}" Visibility="{Binding SelectedOption, Mode=OneWay, ElementName=InputControl, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Automation}"/>
                                </Grid>
                            </UniformGrid>

                            <!--InputControl-->
                            <Grid IsEnabled="{Binding DiffusionService.IsLoaded}" >
                                <Controls:DiffusionInputControl 
                                    x:Name="InputControl"
                                    ViewType="ImageToVideo"
                                    ProcessType="ImageToVideo" 
                                    IsImageInputEnabled="True"
                                    IsControlNetEnabled="False"
                                    Options="{Binding Options, Mode=OneWayToSource}"
                                    UpscaleOptions="{Binding UpscaleOptions, Mode=OneWayToSource}"
                                    ExtractOptions="{Binding ExtractOptions, Mode=OneWayToSource}"
                                    AutomationOptions="{Binding AutomationOptions, Mode=OneWayToSource}"
                                    AutomationProgress="{Binding AutomationProgress, Mode=OneWay}"
                                    Pipeline="{Binding CurrentPipeline, Mode=OneWay}" 
                                    IsExecuting="{Binding DiffusionService.IsExecuting, Mode=OneWay}"
                                    IsAutomating="{Binding IsAutomating, Mode=OneWay}"
                                    IsEnabled="{Binding CurrentPipeline, Mode=OneWay, Converter={StaticResource InverseNullBooleanConverter}}"/>
                            </Grid>

                        </DockPanel>
                    </DockPanel>
                </Border>
            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />


            <!--***Right Panel***-->
            <Grid Grid.Column="2" Grid.Row="0" >

                <!--Content-->
                <DockPanel>

                    <!--Statistics-->
                    <Controls:StatisticsControl 
                        DockPanel.Dock="Bottom"
                        Margin="14,0,14,8"
                        Statistics="{Binding Statistics, Mode=OneWay}"
                        Progress="{Binding Progress, Mode=OneWay}" />

                    <Border Margin="4" IsEnabled="{Binding IsViewBusy, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                        <UniformGrid Columns="2" IsEnabled="{Binding DiffusionService.IsExecuting, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">

                            <!--Inputs-->
                            <UniformGrid >

                                <!--SourceImage1-->
                                <Grid Margin="10,10,10,2" >
                                    <CommonControls:ImageElement 
                                        SplitterVisibility="Auto"
                                        SplitterPosition="Source"
                                        SplitterDirection="LeftToRight" 
                                        IsLoadEnabled="True" 
                                        IsSaveEnabled="False"
                                        IsLoadOverlayEnabled="False"  
                                        SourceChanged="OnSourceImageChanged"
                                        CropWidth="{Binding Options.Width, Mode=OneWay}"
                                        CropHeight="{Binding Options.Height, Mode=OneWay}"
                                        Source="{Binding SourceImage1, Mode=TwoWay}" 
                                        IsInputEnabled="{Binding IsPipelineLoaded, Mode=OneWay}"
                                        OnMediaImport="OnMediaImport"
                                        Title="First Frame"/>
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding SelectedOption, Mode=OneWay, ElementName=InputControl, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Automation}" Value="True"/>
                                                        <Condition Binding="{Binding AutomationOptions.Type, Mode=OneWay, ElementName=InputControl, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=InputFiles}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <MultiDataTrigger.Setters>
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </MultiDataTrigger.Setters>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>

                                <!--SourceImage2-->
                                <Grid Margin="10,10,10,2" Visibility="{Binding Options.IsSource2Enabled, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                    <CommonControls:ImageElement 
                                        SplitterVisibility="Auto"
                                        SplitterPosition="Source"
                                        SplitterDirection="LeftToRight" 
                                        IsLoadEnabled="True" 
                                        IsSaveEnabled="False"
                                        IsLoadOverlayEnabled="False"
                                        CropWidth="{Binding Options.Width, Mode=OneWay}"
                                        CropHeight="{Binding Options.Height, Mode=OneWay}"
                                        Source="{Binding SourceImage2, Mode=TwoWay}" 
                                        IsInputEnabled="{Binding IsPipelineLoaded, Mode=OneWay}"
                                        Title="Last Frame"/>
                                </Grid>

                                <UniformGrid.Style>
                                    <Style TargetType="{x:Type UniformGrid}">
                                        <Setter Property="Rows" Value="1"></Setter>
                                        <Setter Property="Columns" Value="1"></Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Options.IsSource2Enabled, Mode=OneWay}" Value="True">
                                                <Setter Property="Rows" Value="2"></Setter>
                                                <Setter Property="Columns" Value="1"></Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </UniformGrid.Style>
                            </UniformGrid>

                            <!--Output-->
                            <Grid Margin="10,10,10,2" >
                                <CommonControls:VideoStreamElement 
                                    x:Name="ResultControl" 
                                    SplitterVisibility="Auto"
                                    SplitterPosition="Source"
                                    SplitterDirection="LeftToRight"
                                    IsLoadEnabled="False" 
                                    IsLoadOverlayEnabled="False"
                                    IsFrameViewerEnabled="True"
                                    Source="{Binding ResultVideo, Mode=TwoWay}" 
                                    OverlaySource="{Binding CompareVideo, Mode=TwoWay}" 
                                    Volume="{Binding Settings.VolumeOutput, Mode=TwoWay}"
                                    IsVolumeMute="{Binding Settings.IsVolumeOutputMute, Mode=TwoWay}"/>
                            </Grid>
                        </UniformGrid>
                    </Border>
                </DockPanel>

            </Grid>
        </Grid>
    </Grid>
</Views:ViewBaseDiffusion>
