<Views:ViewBaseDiffusion x:Class="Amuse.App.Views.TextToMusicView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Amuse.App.Views"
    xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
    xmlns:Controls="clr-namespace:Amuse.App.Controls"
    xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:TextToMusicView}}}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="380"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="Auto" MaxWidth="330" />
            </Grid.ColumnDefinitions>

            <!--***Left Panel***-->
            <Grid Grid.Column="0">
                <Border Margin="4">
                    <DockPanel x:Name="LeftPanelContainer" Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">

                        <!--ModelControl-->
                        <Grid DockPanel.Dock="Top" IsEnabled="{Binding DiffusionService.IsLoading, Converter={StaticResource InverseBoolConverter}}">
                            <Grid IsEnabled="{Binding DiffusionService.IsExecuting, Converter={StaticResource InverseBoolConverter}}">
                                <Grid IsEnabled="{Binding IsAutomating, Converter={StaticResource InverseBoolConverter}}">
                                    <Controls:DiffusionModelControl
                                        x:Name="ModelControl"
                                        ViewType="TextToMusic"
                                        ProcessType="TextToAudio"
                                        IsLoraSupported="False"
                                        IsUpscalerSupported="False"
                                        IsExtractorSupported="False"
                                        IsControlNetSupported="False"
                                        Settings="{Binding Settings, Mode=OneWay}" 
                                        IsPipelineLoaded="{Binding IsPipelineLoaded, Mode=OneWay}"
                                        DownloadService="{Binding DownloadService, Mode=OneTime}"
                                        NavigationService="{Binding NavigationService, Mode=OneTime}"
                                        SelectionChanged="SelectedPipelineChanged"/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <DockPanel DockPanel.Dock="Bottom">

                            <!--Execute/Cancel-->
                            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="30" >
                                <DockPanel>
                                    <Button DockPanel.Dock="Left" Width="30" Command="{Binding StopCommand}" Visibility="{Binding DiffusionService.IsCanceling, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Immediately stops generation by closing the backend process." ToolTipService.InitialShowDelay="200">
                                        <CommonControls:FontAwesome Icon="f00d" Color="{StaticResource DangerColour}" />
                                    </Button>
                                    <Grid IsEnabled="{Binding DiffusionService.IsCanceling, Converter={StaticResource InverseBoolConverter}}">
                                        <Button Command="{Binding CancelCommand}" >
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Cancel" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DiffusionService.IsCanceling}" Value="True">
                                                            <Setter Property="Content" Value="Canceling" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DockPanel>
                                <Grid IsEnabled="{Binding IsSelectionValid, ElementName=ModelControl}">
                                    <Button Content="Generate" Command="{Binding ExecuteCommand}" Visibility="{Binding SelectedOption, ElementName=InputControl, Converter={StaticResource InverseEnumToVisibilityConverter}, ConverterParameter=Automation}"/>
                                    <Button Content="Automate" Command="{Binding ExecuteAutomationCommand}" Visibility="{Binding SelectedOption, ElementName=InputControl, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Automation}"/>
                                </Grid>
                            </UniformGrid>


                            <!--InputControl-->
                            <StackPanel >
                                <Controls:AudioDiffusionInputControl
                                    x:Name="InputControl"
                                    ViewType="TextToMusic"
                                    ProcessType="TextToAudio"
                                    Options="{Binding Options, Mode=OneWayToSource}"
                                    AutomationOptions="{Binding AutomationOptions, Mode=OneWayToSource}"
                                    AutomationProgress="{Binding AutomationProgress, Mode=OneWay}"
                                    Pipeline="{Binding CurrentPipeline, Mode=OneWay}" 
                                    IsExecuting="{Binding DiffusionService.IsExecuting, Mode=OneWay}"
                                    IsAutomating="{Binding IsAutomating, Mode=OneWay}"
                                    IsEnabled="{Binding IsPipelineLoaded}"/>
                                <DockPanel Margin="0,-6,0,0" Visibility="{Binding SelectedOption, ElementName=InputControl, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Options}">
                                    <TextBlock DockPanel.Dock="Top" Text="Reference Audio (optional)" Style="{StaticResource FieldTextBlockStyle}" Margin="0,0,0,2"/>
                                    <CommonControls:AudioStreamElement 
                                        Height="160"
                                        Source="{Binding SourceAudio, Mode=TwoWay}" 
                                        IsInputEnabled="{Binding IsPipelineLoaded}"
                                        IsLoadEnabled="True" 
                                        IsSaveEnabled="False"
                                        OnMediaImport="OnMediaImport"/>
                                </DockPanel>
                            </StackPanel>

                        </DockPanel>
                    </DockPanel>
                </Border>
            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />


            <!--***Right Panel***-->
            <Grid Grid.Column="2" Grid.Row="0" >

                <!--Content-->
                <DockPanel>

                    <!--Statistics-->
                    <Controls:StatisticsControl 
                        DockPanel.Dock="Bottom"
                        Margin="14,0,14,8"
                        Statistics="{Binding Statistics}"
                        Progress="{Binding Progress}" />

                    <Border Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">
                        <DockPanel>

                            <!--Output-->
                            <DockPanel DockPanel.Dock="Bottom" Margin="10,10,10,4">
                                <DockPanel Height="150">
                                    <TextBlock DockPanel.Dock="Top" Text="Audio Result" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:AudioStreamElement Source="{Binding ResultAudio, Mode=TwoWay}" IsLoadEnabled="False" IsInputEnabled="{Binding IsPipelineLoaded}" />
                                </DockPanel>
                            </DockPanel>

                            <!--Prompt-->
                            <Grid Margin="10,0,10,0" IsEnabled="{Binding IsPipelineLoaded}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*"/>
                                    <RowDefinition Height="5*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" >
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="Style" Style="{StaticResource FieldTextBlockStyle}"/>
                                        <TextBox Text="{Binding Options.Prompt, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap"/>
                                    </DockPanel>
                                </DockPanel>
                                <DockPanel Grid.Row="1" >
                                    <DockPanel >
                                        <TextBlock DockPanel.Dock="Top" Text="Lyrics" Style="{StaticResource FieldTextBlockStyle}"/>
                                        <TextBox Text="{Binding Options.Prompt2, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
                                    </DockPanel>
                                </DockPanel>
                            </Grid>

                        </DockPanel>
                    </Border>
                </DockPanel>

            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />


            <!--Help/Information-->
            <Grid Grid.Column="4" Grid.Row="0" >

                <StackPanel Margin="8,4,4,8" Width="318" IsEnabled="{Binding IsPipelineLoaded}">

                    <!--Style-->
                    <DockPanel DockPanel.Dock="Top" >
                        <StackPanel DockPanel.Dock="Top" TextBlock.FontSize="11">
                            <TextBlock Text="Style" Style="{StaticResource FieldTextBlockStyle}"/>
                            <TextBlock Text="Combine genre, instruments, mood, and style for the most accurate results. For example, 'Dreamy lo-fi hip-hop with soft piano and bedroom-pop production' works better than a single-word prompt." TextWrapping="Wrap" Opacity=".9"/>
                            <StackPanel Margin="0,6,0,0" Opacity=".9">
                                <TextBlock Text="- Name the genre: synthwave, hip-hop, lo-fi, or folk"/>
                                <TextBlock Text="- List instruments: 808 drums, piano, or acoustic guitar"/>
                                <TextBlock Text="- Define the mood: energetic, dreamy, or melancholic"/>
                                <TextBlock Text="- Production: polished, live recording, or bedroom pop"/>
                            </StackPanel>
                        </StackPanel>
                        <DockPanel>
                            <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="0,12,0,0" VerticalAlignment="Bottom" Opacity=".8" Height="22">
                                <Button Content="Style Sample" Command="{Binding AppendLyricExampleCommand}" CommandParameter="Prompt1" FontSize="11" />
                                <Button Content="Style Sample" Command="{Binding AppendLyricExampleCommand}" CommandParameter="Prompt2" FontSize="11" />
                                <Button Content="Style Sample" Command="{Binding AppendLyricExampleCommand}" CommandParameter="Prompt3" FontSize="11" />
                            </UniformGrid>
                        </DockPanel>
                    </DockPanel>

                    <!--Lyric-->
                    <DockPanel Margin="0,20,0,0">
                        <StackPanel DockPanel.Dock="Top" TextBlock.FontSize="11">
                            <TextBlock Text="Lyrics" Style="{StaticResource FieldTextBlockStyle}"/>
                            <StackPanel Opacity=".9">
                                <TextBlock Text="- Keep lines around 6-10 syllables"/>
                                <TextBlock Text="- Use UPPERCASE for words you want emphasized or shouted"/>
                                <TextBlock Text="- Use ( ) for background vocals or echoes"/>
                                <TextBlock Text="- Add descriptors: [Chorus - anthemic] or [Verse - whispered]"/>
                            </StackPanel>
                            <TextBlock Text="Lyric Tags" Margin="0,8,0,0" Style="{StaticResource FieldTextBlockStyle}"/>
                        </StackPanel>

                        <Grid DockPanel.Dock="Top" Opacity=".9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Button Grid.Column="0" Grid.Row="0" Content="[Intro]"  FontSize="11" HorizontalContentAlignment="Left" Padding="0" Style="{StaticResource TransparentButton}" Command="{Binding AppendLyricCommand}" CommandParameter="[Intro]"/>
                            <Button Grid.Column="0" Grid.Row="1" Content="[Verse]" FontSize="11" HorizontalContentAlignment="Left" Padding="0" Style="{StaticResource TransparentButton}" Command="{Binding AppendLyricCommand}" CommandParameter="[Verse]" />
                            <Button Grid.Column="0" Grid.Row="2" Content="[Pre-Chorus]" FontSize="11" HorizontalContentAlignment="Left" Padding="0" Style="{StaticResource TransparentButton}" Command="{Binding AppendLyricCommand}" CommandParameter="[Pre-Chorus]" />
                            <Button Grid.Column="0" Grid.Row="3" Content="[Chorus]" FontSize="11" HorizontalContentAlignment="Left" Padding="0" Style="{StaticResource TransparentButton}" Command="{Binding AppendLyricCommand}" CommandParameter="[Chorus]" />
                            <Button Grid.Column="0" Grid.Row="4" Content="[Bridge]" FontSize="11" HorizontalContentAlignment="Left" Padding="0" Style="{StaticResource TransparentButton}" Command="{Binding AppendLyricCommand}" CommandParameter="[Bridge]" />
                            <Button Grid.Column="0" Grid.Row="5" Content="[Instrumental]" FontSize="11" HorizontalContentAlignment="Left" Padding="0" Style="{StaticResource TransparentButton}" Command="{Binding AppendLyricCommand}" CommandParameter="[Instrumental]"/>
                            <Button Grid.Column="0" Grid.Row="6" Content="[Outro]" FontSize="11" HorizontalContentAlignment="Left" Padding="0" Style="{StaticResource TransparentButton}" Command="{Binding AppendLyricCommand}" CommandParameter="[Outro]"/>
                            <TextBlock Grid.Column="1" Grid.Row="0" FontSize="11" Text="Sets up atmosphere, usually instrumental" Margin="0,1"/>
                            <TextBlock Grid.Column="1" Grid.Row="1" FontSize="11" Text="Main storytelling section, moderate energy" Margin="0,1"/>
                            <TextBlock Grid.Column="1" Grid.Row="2" FontSize="11" Text="Builds tension before the chorus" Margin="0,1"/>
                            <TextBlock Grid.Column="1" Grid.Row="3" FontSize="11" Text="Emotional peak, highest energy" Margin="0,1"/>
                            <TextBlock Grid.Column="1" Grid.Row="4" FontSize="11" Text="A shift — different melody, different feel" Margin="0,1"/>
                            <TextBlock Grid.Column="1" Grid.Row="5" FontSize="11" Text="No vocals, just instruments" Margin="0,1"/>
                            <TextBlock Grid.Column="1" Grid.Row="6" FontSize="11" Text="Winds down, often fades" Margin="0,1"/>
                        </Grid>
                        <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="0,12,0,0" Opacity=".8" Height="22">
                            <Button Content="Lyrics Sample" Command="{Binding AppendLyricExampleCommand}" CommandParameter="Lyrics1" FontSize="11"/>
                            <Button Content="Lyrics Sample" Command="{Binding AppendLyricExampleCommand}" CommandParameter="Lyrics2" FontSize="11"/>
                            <Button Content="Lyrics Sample" Command="{Binding AppendLyricExampleCommand}" CommandParameter="Lyrics3" FontSize="11"/>
                        </UniformGrid>
                        <TextBlock />
                    </DockPanel>

                    <!--Reference Audio-->
                    <StackPanel TextBlock.FontSize="11">
                        <TextBlock Text="Reference Audio" Style="{StaticResource FieldTextBlockStyle}"/>
                        <StackPanel Opacity=".9">
                            <TextBlock Text="Use an audio optional file as a template for the final output"/>
                            <TextBlock Text="- Matches the tonal warmth and frequency balance"/>
                            <TextBlock Text="- Replicates specific instrumental textures and grain"/>
                            <TextBlock Text="- Captures the unique rhythmic and atmospheric vibe"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

            </Grid>

        </Grid>
    </Grid>
</Views:ViewBaseDiffusion>
