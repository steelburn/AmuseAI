<Views:ViewBaseDiffusion x:Class="Amuse.App.Views.FrameToFrameView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Amuse.App.Views"
    xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
    xmlns:Controls="clr-namespace:Amuse.App.Controls"
    xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:FrameToFrameView}}}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="380"/>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!--***Left Panel***-->
            <Grid Grid.Column="0">
                <Border Margin="4">
                    <DockPanel x:Name="LeftPanelContainer" Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">

                        <!--ModelControl-->
                        <Grid DockPanel.Dock="Top" IsEnabled="{Binding DiffusionService.IsLoading, Converter={StaticResource InverseBoolConverter}}">
                            <Grid IsEnabled="{Binding DiffusionService.IsExecuting, Converter={StaticResource InverseBoolConverter}}">
                                <Grid IsEnabled="{Binding IsAutomating, Converter={StaticResource InverseBoolConverter}}">
                                    <Controls:DiffusionModelControl
                                        x:Name="ModelControl"
                                        ViewType="FrameToFrame"
                                        ProcessType="ImageEdit"
                                        IsLoraSupported="True"
                                        IsUpscalerSupported="True"
                                        Settings="{Binding Settings, Mode=OneWay}" 
                                        IsPipelineLoaded="{Binding IsPipelineLoaded, Mode=OneWay}"
                                        DownloadService="{Binding DownloadService, Mode=OneTime}"
                                        NavigationService="{Binding NavigationService, Mode=OneTime}"
                                        SelectionChanged="SelectedPipelineChanged"/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <DockPanel DockPanel.Dock="Bottom" >

                            <!--Execute/Cancel-->
                            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="30" >
                                <DockPanel>
                                    <Button DockPanel.Dock="Left" Width="30" Command="{Binding StopCommand}" Visibility="{Binding DiffusionService.IsCanceling, Converter={StaticResource BooleanToVisibilityConverter}}" ToolTip="Immediately stops generation by closing the backend process." ToolTipService.InitialShowDelay="200">
                                        <CommonControls:FontAwesome Icon="f00d" Color="{StaticResource DangerColour}" />
                                    </Button>
                                    <Grid IsEnabled="{Binding DiffusionService.IsCanceling, Converter={StaticResource InverseBoolConverter}}">
                                        <Button Command="{Binding CancelCommand}" >
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Content" Value="Cancel" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DiffusionService.IsCanceling}" Value="True">
                                                            <Setter Property="Content" Value="Canceling" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DockPanel>
                                <Grid IsEnabled="{Binding IsSelectionValid, ElementName=ModelControl}">
                                    <Button Content="Generate" Command="{Binding ExecuteCommand}" Visibility="{Binding SelectedOption, ElementName=InputControl, Converter={StaticResource InverseEnumToVisibilityConverter}, ConverterParameter=Automation}"/>
                                    <Button Content="Automate" Command="{Binding ExecuteAutomationCommand}" Visibility="{Binding SelectedOption, ElementName=InputControl, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Automation}"/>
                                </Grid>
                            </UniformGrid>

                            <!--Batch Progress-->
                            <Grid DockPanel.Dock="Bottom">
                                <CommonControls:ProgressElement DockPanel.Dock="Bottom" Progress="{Binding VideoFrameProgress}" Margin="0,0,0,6" />
                            </Grid>

                            <!--InputControl-->
                            <Grid IsEnabled="{Binding DiffusionService.IsLoaded}">
                                <Controls:DiffusionInputControl 
                                    x:Name="InputControl"
                                    ViewType="FrameToFrame"
                                    ProcessType="ImageEdit"
                                    Options="{Binding Options, Mode=OneWayToSource}"
                                    UpscaleOptions="{Binding UpscaleOptions, Mode=OneWayToSource}"
                                    AutomationOptions="{Binding AutomationOptions, Mode=OneWayToSource}"
                                    AutomationProgress="{Binding AutomationProgress, Mode=OneWay}"
                                    Pipeline="{Binding CurrentPipeline, Mode=OneWay}" 
                                    IsExecuting="{Binding DiffusionService.IsExecuting, Mode=OneWay}"
                                    IsAutomating="{Binding IsAutomating, Mode=OneWay}"
                                    IsImageInputEnabled="True"
                                    IsControlNetEnabled="False"
                                    IsEnabled="{Binding CurrentPipeline, Mode=OneWay, Converter={StaticResource InverseNullBooleanConverter}}"/>
                            </Grid>

                        </DockPanel>
                    </DockPanel>
                </Border>
            </Grid>


            <!--GridSplitter-->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Width="5" Opacity=".4" Margin="0,20" />


            <!--***Right Panel***-->
            <Grid Grid.Column="2" Grid.Row="0" >

                <!--Content-->
                <DockPanel>

                    <!--Statistics-->
                    <Controls:StatisticsControl 
                        DockPanel.Dock="Bottom"
                        Margin="14,0,14,8"
                        Statistics="{Binding Statistics}"
                        Progress="{Binding Progress}" />

                    <Border Margin="4" IsEnabled="{Binding IsViewBusy, Converter={StaticResource InverseBoolConverter}}">
                        <UniformGrid Columns="2">

                            <!--Inputs-->
                            <Grid Margin="10,10,10,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*" />
                                    <RowDefinition Height="1*" />
                                </Grid.RowDefinitions>


                                <!--SourceVideo/SourceImage1-->
                                <Grid>
                                    <CommonControls:VideoStreamElement 
                                        SplitterVisibility="Auto"
                                        SplitterPosition="Source"
                                        SplitterDirection="LeftToRight"
                                        IsLoadEnabled="True" 
                                        IsSaveEnabled="False"
                                        IsLoadOverlayEnabled="False"
                                        Source="{Binding SourceVideo, Mode=TwoWay}" 
                                        ImageFrame="{Binding SourceImage1.Image}"
                                        Volume="{Binding Settings.VolumeInput, Mode=TwoWay}"
                                        IsVolumeMute="{Binding Settings.IsVolumeInputMute, Mode=TwoWay}"
                                        IsInputEnabled="{Binding IsPipelineLoaded}"
                                        IsEnabled="{Binding IsAutomating, Converter={StaticResource InverseBoolConverter}}"
                                        OnMediaImport="OnMediaImport"/>
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Setter Property="Grid.Row" Value="0"/>
                                            <Setter Property="Grid.Column" Value="0"/>
                                            <Setter Property="Grid.RowSpan" Value="2"/>
                                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                                            <Setter Property="Margin" Value="0,0,0,0"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Options.IsSource1Enabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Margin" Value="0,0,0,0"/>
                                                    <Setter Property="Grid.RowSpan" Value="2"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.IsSource2Enabled}" Value="True">
                                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                                    <Setter Property="Grid.RowSpan" Value="1"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.IsSource3Enabled}" Value="True">
                                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                                    <Setter Property="Grid.RowSpan" Value="1"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.IsSource4Enabled}" Value="True">
                                                    <Setter Property="Margin" Value="0,0,4,4"/>
                                                    <Setter Property="Grid.RowSpan" Value="1"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding SelectedOption, Mode=OneWay, ElementName=InputControl, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Automation}" Value="True"/>
                                                        <Condition Binding="{Binding AutomationOptions.Type, Mode=OneWay, ElementName=InputControl, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=InputFiles}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <MultiDataTrigger.Setters>
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </MultiDataTrigger.Setters>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>

                                <!--SourceImage2-->
                                <Grid>
                                    <CommonControls:ImageElement 
                                        SplitterVisibility="Auto"
                                        SplitterPosition="Source"
                                        SplitterDirection="LeftToRight"
                                        IsLoadEnabled="True" 
                                        IsSaveEnabled="False"
                                        IsLoadOverlayEnabled="False"   
                                        CropWidth="{Binding Options.Width, Mode=OneWay}"
                                        CropHeight="{Binding Options.Height, Mode=OneWay}"
                                        Source="{Binding SourceImage2, Mode=TwoWay}" 
                                        IsInputEnabled="{Binding IsPipelineLoaded}"
                                        OnMediaImport="OnMediaImport"
                                        Title="Image 1"/>
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Setter Property="Grid.Row" Value="0"/>
                                            <Setter Property="Grid.Column" Value="1"/>
                                            <Setter Property="Grid.ColumnSpan" Value="1"/>
                                            <Setter Property="Margin" Value="0,0,0,0"/>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Options.IsSource2Enabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Margin" Value="0,4,0,0"/>
                                                    <Setter Property="Grid.Row" Value="1"/>
                                                    <Setter Property="Grid.Column" Value="0"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.IsSource3Enabled}" Value="True">
                                                    <Setter Property="Margin" Value="0,4,4,0"/>
                                                    <Setter Property="Grid.Row" Value="1"/>
                                                    <Setter Property="Grid.Column" Value="0"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.IsSource4Enabled}" Value="True">
                                                    <Setter Property="Margin" Value="4,0,0,4"/>
                                                    <Setter Property="Grid.Row" Value="0"/>
                                                    <Setter Property="Grid.Column" Value="1"/>
                                                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>

                                <!--SourceImage3-->
                                <Grid>
                                    <CommonControls:ImageElement 
                                        SplitterVisibility="Auto"
                                        SplitterPosition="Source"
                                        SplitterDirection="LeftToRight"
                                        IsLoadEnabled="True" 
                                        IsSaveEnabled="False"
                                        IsLoadOverlayEnabled="False"  
                                        CropWidth="{Binding Options.Width}"
                                        CropHeight="{Binding Options.Height}"
                                        Source="{Binding SourceImage3, Mode=TwoWay}" 
                                        IsInputEnabled="{Binding IsPipelineLoaded}"
                                        OnMediaImport="OnMediaImport"
                                        Title="Image 2"/>
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Setter Property="Margin" Value="0,0,0,0"/>
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Options.IsSource3Enabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Margin" Value="4,4,0,0"/>
                                                    <Setter Property="Grid.Row" Value="1"/>
                                                    <Setter Property="Grid.Column" Value="1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Options.IsSource4Enabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Setter Property="Margin" Value="0,4,4,0"/>
                                                    <Setter Property="Grid.Row" Value="1"/>
                                                    <Setter Property="Grid.Column" Value="0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>

                                <!--SourceImage4-->
                                <Grid>
                                    <CommonControls:ImageElement 
                                        SplitterVisibility="Auto"
                                        SplitterPosition="Source"
                                        SplitterDirection="LeftToRight" 
                                        IsLoadEnabled="True" 
                                        IsSaveEnabled="False"
                                        IsLoadOverlayEnabled="False"  
                                        CropWidth="{Binding Options.Width}"
                                        CropHeight="{Binding Options.Height}"
                                        Source="{Binding SourceImage4, Mode=TwoWay}" 
                                        IsInputEnabled="{Binding IsPipelineLoaded}"
                                        OnMediaImport="OnMediaImport"
                                        Title="Image 3"/>
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Setter Property="Grid.Row" Value="1"/>
                                            <Setter Property="Grid.Column" Value="1"/>
                                            <Setter Property="Margin" Value="4,4,0,0"/>
                                            <Setter Property="Visibility" Value="Collapsed"></Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Options.IsSource4Enabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                </Grid>
                            </Grid>

                            <!--Output-->
                            <Grid Margin="10,10,10,2" >
                                <CommonControls:VideoStreamElement 
                                    x:Name="ResultControl" 
                                    SplitterVisibility="Auto"
                                    SplitterPosition="Source"
                                    SplitterDirection="LeftToRight"
                                    IsLoadEnabled="False" 
                                    IsLoadOverlayEnabled="False"
                                    IsFrameViewerEnabled="True"
                                    Source="{Binding ResultVideo, Mode=TwoWay}" 
                                    ImageFrame="{Binding ResultImage.Image}"
                                    OverlaySource="{Binding CompareVideo, Mode=TwoWay}" 
                                    Volume="{Binding Settings.VolumeOutput, Mode=TwoWay}"
                                    IsVolumeMute="{Binding Settings.IsVolumeOutputMute, Mode=TwoWay}"/>
                            </Grid>
                        </UniformGrid>
                    </Border>
                </DockPanel>

            </Grid>
        </Grid>
    </Grid>
</Views:ViewBaseDiffusion>
