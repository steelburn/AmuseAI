<CommonControls:BaseControl x:Class="Amuse.App.Controls.VideoTimelineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:Amuse.App.Controls"
             xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF" 
             xmlns:CommonBehaviors="clr-namespace:TensorStack.WPF.Behaviors;assembly=TensorStack.WPF">
    <DockPanel DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}}">

        <!--Details-->
        <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="170" Margin="0,8,0,4">

            <!--Preview Frame-->
            <DockPanel HorizontalAlignment="Left">
                <Border DockPanel.Dock="Left" BorderBrush="{StaticResource ContainerBorder}" BorderThickness="1">
                    <Viewbox>
                        <Grid>
                            <Image Stretch="Uniform" 
                                MinWidth="384"
                                MinHeight="256" 
                                Width="{Binding TimelineThumbWidth}" 
                                Height="{Binding TimelineThumbHeight}" 
                                Source="{Binding PreviewFrame.Frame, Converter={StaticResource VideoFrameToBitmapConverter}, TargetNullValue={StaticResource PlaceholderVideo}, FallbackValue={StaticResource PlaceholderVideo}}">
                            </Image>
                            <Image Stretch="Uniform" 
                                MinWidth="384"
                                MinHeight="256" 
                                Width="{Binding TimelineThumbWidth}" 
                                Height="{Binding TimelineThumbHeight}" 
                                Source="{Binding PreviewOverlay.Frame, Converter={StaticResource VideoFrameToBitmapConverter}, TargetNullValue={StaticResource PlaceholderVideo}, FallbackValue={StaticResource PlaceholderVideo}}">
                            </Image>
                        </Grid>
                    </Viewbox>
                </Border>
                <DockPanel Margin="4,0,0,0">

                    <!--Import Buttons-->
                    <UniformGrid DockPanel.Dock="Bottom" Columns="3" Height="30" Width="300">
                        <Border Style="{StaticResource VideoDropZoneStyle}">
                            <Button Content="Add Video" Command="{Binding LoadVideoCommand}" Drop="OnTimelineDrop"/>
                        </Border>
                        <Border>
                            <Button Content="Add Image" Command="{Binding LoadImageCommand}" Drop="OnImageDrop"/>
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource ImageDropZoneStyle}">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TimelineFrameRate, RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsControlBusy, RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <Border>
                            <Button Content="Add Overlay" Command="{Binding LoadOverlayCommand}" Drop="OnOverlayDrop"/>
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource ImageDropZoneStyle}">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TimelineFrameRate, RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsControlBusy, RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </UniformGrid>

                    <!--Timeline Details-->
                    <StackPanel>
                        <UniformGrid Columns="2">
                            <TextBlock Text="Width:" Opacity=".7" FontStyle="Italic"/>
                            <TextBlock Text="{Binding TimelineWidth, FallbackValue=0, TargetNullValue=0, StringFormat={}{0} px}" Opacity=".9"/>
                            <TextBlock Text="Height:" Opacity=".7" FontStyle="Italic"/>
                            <TextBlock Text="{Binding TimelineHeight, FallbackValue=0, TargetNullValue=0, StringFormat={}{0} px}" Opacity=".9"/>
                            <TextBlock Text="FrameRate:" Opacity=".7" FontStyle="Italic"/>
                            <TextBlock Text="{Binding TimelineFrameRate, FallbackValue=0, TargetNullValue=0, StringFormat={}{0:N0} fps}" Opacity=".9"/>
                            <TextBlock Text="Segments:" Opacity=".7" FontStyle="Italic"/>
                            <TextBlock Text="{Binding TimelineSegements.Count, Mode=OneWay}" Opacity=".9"/>
                            <TextBlock Text="Timeline Frame:" Opacity=".7" FontStyle="Italic"/>
                            <TextBlock Text="{Binding TimelinePosition}" Opacity=".9"/>
                            <TextBlock Text="Timeline Frames:" Opacity=".7" FontStyle="Italic"/>
                            <TextBlock Text="{Binding TimelineLength}" Opacity=".9"/>
                        </UniformGrid>
                        <UniformGrid Columns="2" Margin="0,6,0,0">
                            <TextBlock Text="Current Time:" Opacity=".7" VerticalAlignment="Center" FontStyle="Italic"/>
                            <TextBlock Text="{Binding TimelinePositionTime, FallbackValue=00:00:00, StringFormat={}hh\\:mm\\:ss\\.ff}" FontSize="14" Opacity=".9"/>
                            <TextBlock Text="Timeline Time:" Opacity=".7" VerticalAlignment="Center" FontStyle="Italic"/>
                            <TextBlock Text="{Binding TimelineLengthTime, FallbackValue=00:00:00, StringFormat={}hh\\:mm\\:ss\\.ff}" FontSize="14" Opacity=".9"/>
                        </UniformGrid>
                    </StackPanel>
                </DockPanel>
            </DockPanel>

            <!--Preview Controls - Save/Cancel-->
            <DockPanel Width="400" HorizontalAlignment="Right">
                <DockPanel>
                    <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="30">
                        <Button Content="Cancel" Command="{Binding CancelCommand}"/>
                        <Button Content="Save" Command="{Binding SaveVideoCommand}"/>
                    </UniformGrid>
                    <StackPanel>
                        <CommonControls:SliderControl Text="Frame Width" Minimum="3" Maximum="{Binding PreviewFrameSize}" Value="{Binding TimelineFrameWidth}" TickFrequency="1" ValueFormat="N0"/>
                        <CommonControls:SliderControl Text="Frame Size" Minimum="20" Maximum="260" TickFrequency="10" ValueFormat="N0" Value="{Binding PreviewFrameSize}"/>
                        <CommonControls:SliderControl Text="Preview Quality" Minimum="20" Maximum="260" TickFrequency="10" ValueFormat="N0" Value="{Binding TimelineThumbHeight}"/>
                        <CheckBox Content="Enable Audio Processing" IsChecked="{Binding IsAudioEnabled}"  Margin="0,5,0,0"/>
                    </StackPanel>
                </DockPanel>
            </DockPanel>

        </UniformGrid>

        <!--Timeline-->
        <Border BorderBrush="{StaticResource ContainerBorder}" BorderThickness="1" IsHitTestVisible="{Binding IsControlBusy, Converter={StaticResource InverseBoolConverter}}">
            <DockPanel>
                <Border DockPanel.Dock="Bottom" Background="{StaticResource ContainerBackground}" BorderBrush="{StaticResource ContainerBorder}" BorderThickness="0,1,0,0" Padding="4,4,4,4">
                    <DockPanel>

                        <!--Time Label-->
                        <DockPanel DockPanel.Dock="Top" Height="20" Opacity=".8">
                            <TextBlock DockPanel.Dock="Left" Text="00:00.00" FontSize="9" TextAlignment="Right"/>
                            <ItemsControl ItemsSource="{Binding TimelineMarkers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FallbackValue=00:00:00, StringFormat={}mm\\:ss\\.ff}" FontSize="9" TextAlignment="Right"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid IsItemsHost="True" Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </DockPanel>

                        <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0" Height="22">
                            <DockPanel.Resources>
                                <Style x:Key="OptionButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="ToolTipService.Placement" Value="Top"/>
                                    <Setter Property="ToolTipService.InitialShowDelay" Value="200"/>
                                    <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                                </Style>
                            </DockPanel.Resources>

                            <!--Timeline Controls-->
                            <UniformGrid DockPanel.Dock="Left" Rows="1">
                                <Button Command="{Binding TimelineClearCommand}" Width="50" Style="{StaticResource OptionButton}" ToolTip="Clear Timeline">
                                    <CommonControls:FontAwesome Icon="e2ab" Size="12"/>
                                </Button>
                                <Button Command="{Binding SaveVideoCommand}" Style="{StaticResource OptionButton}" ToolTip="Save Video">
                                    <CommonControls:FontAwesome Icon="f0c7" Size="12"/>
                                </Button>
                                <TextBox x:Name="ExtendTimelineTextBox" DockPanel.Dock="Right" Text="120" TextAlignment="Center"/>
                                <Button Command="{Binding TimelineExtendCommand}" CommandParameter="{Binding Text, ElementName=ExtendTimelineTextBox, Converter={StaticResource StringToIntConverter}}" Style="{StaticResource OptionButton}" ToolTip="Extend Timeline">
                                    <CommonControls:FontAwesome Icon="e6c4" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelineTrimCommand}" Style="{StaticResource OptionButton}" ToolTip="Trim Timeline">
                                    <CommonControls:FontAwesome Icon="e4ba" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelineZoomInCommand}" Style="{StaticResource OptionButton}" ToolTip="Zoom In">
                                    <CommonControls:FontAwesome Icon="f00e" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelineZoomOutCommand}" Style="{StaticResource OptionButton}" ToolTip="Zoom Out">
                                    <CommonControls:FontAwesome Icon="f010" Size="12"/>
                                </Button>
                            </UniformGrid>

                            <!--Segment Controls-->
                            <UniformGrid DockPanel.Dock="Right" Rows="1">
                                <Button Command="{Binding SegmentRemoveFrameCommand}" Width="50" Style="{StaticResource OptionButton}" ToolTip="Remove Selected Frames(s)">
                                    <CommonControls:FontAwesome Icon="f0c4" Size="12"/>
                                </Button>
                                <Button Command="{Binding SegmentSaveFrameCommand}" Style="{StaticResource OptionButton}" ToolTip="Save Selected Frame To History">
                                    <CommonControls:FontAwesome Icon="f03e" Size="12"/>
                                </Button>
                                <Button Command="{Binding SegmentSplitCommand}" Style="{StaticResource OptionButton}" ToolTip="Split Segment">
                                    <CommonControls:FontAwesome Icon="e254" Size="12"/>
                                </Button>
                                <Button Command="{Binding SegmentCopyCommand}" Style="{StaticResource OptionButton}" ToolTip="Copy Segment">
                                    <CommonControls:FontAwesome Icon="f0c5" Size="12"/>
                                </Button>
                                <Button Command="{Binding SegmentMoveUpCommand}" Style="{StaticResource OptionButton}" ToolTip="Move Segment Up">
                                    <CommonControls:FontAwesome Icon="f077" Size="12"/>
                                </Button>
                                <Button Command="{Binding SegmentMoveDownCommand}" Style="{StaticResource OptionButton}" ToolTip="Move Segment Down">
                                    <CommonControls:FontAwesome Icon="f078" Size="12"/>
                                </Button>
                                <Button Command="{Binding SegmentRemoveCommand}" Style="{StaticResource OptionButton}" ToolTip="Remove Segment">
                                    <CommonControls:FontAwesome Icon="f2ed" Size="12"/>
                                </Button>
                            </UniformGrid>

                            <!--Media Controls-->
                            <UniformGrid Rows="1" Columns="7" HorizontalAlignment="Center">
                                <Button Command="{Binding TimelineStartCommand}" Width="50">
                                    <CommonControls:FontAwesome Icon="f100" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelinePrevCommand}">
                                    <CommonControls:FontAwesome Icon="f104" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelinePauseCommand}">
                                    <CommonControls:FontAwesome Icon="f04c" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelinePlayCommand}">
                                    <CommonControls:FontAwesome Icon="f04b" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelineStopCommand}">
                                    <CommonControls:FontAwesome Icon="f04d" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelineNextCommand}">
                                    <CommonControls:FontAwesome Icon="f105" Size="12"/>
                                </Button>
                                <Button Command="{Binding TimelineEndCommand}">
                                    <CommonControls:FontAwesome Icon="f101" Size="12"/>
                                </Button>
                            </UniformGrid>
                        </DockPanel>

                        <!--Timeline Slider-->
                        <Slider x:Name="TimelineSlider" Margin="0,4" Value="{Binding TimelinePosition}" Maximum="{Binding TimelinePositions}" TickFrequency="1" SmallChange="1" LargeChange="1" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True" ValueChanged="OnTimelineSliderChanged">
                            <i:Interaction.Behaviors>
                                <CommonBehaviors:SliderMouseWheelBehavior/>
                            </i:Interaction.Behaviors>
                        </Slider>
                    </DockPanel>
                </Border>

                <CommonControls:ProgressElement DockPanel.Dock="Bottom" Progress="{Binding Progress}" Height="6"/>
                <Grid>
                    <Border x:Name="DragDropContainer" Style="{StaticResource VideoDropZoneStyle}">
                        <ScrollViewer x:Name="TimelineViewer"
                            Margin="0,1,0,1"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Hidden" 
                            Drop="OnTimelineDrop"
                            PreviewKeyUp="OnTimelineViewerKeyUp"
                            PreviewMouseWheel="OnTimelineViewerMouseWheel">
                            <ItemsControl ItemsSource="{Binding TimelineSegements}" VerticalAlignment="Center">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ListBox ItemsSource="{Binding VideoFrames}" RequestBringIntoView="OnTimelineSegementRequestBringIntoView" MouseLeftButtonUp="OnTimelineSegementMouseUp" MouseDoubleClick="OnTimelineSegementMouseDoubleClick" Background="{StaticResource TransparentBrush}" BorderThickness="0" Padding="0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderThickness="1,2"
                                                            Width="{Binding TimelineFrameWidth, RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}}"
                                                            Height="{Binding PreviewFrameSize, RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}}">
                                                        <Grid>
                                                            <Image Stretch="Uniform" 
                                                                Source="{Binding Frame, Converter={StaticResource VideoFrameToBitmapConverter}, TargetNullValue={StaticResource PlaceholderVideo}}" 
                                                                Width="{Binding PreviewFrameSize, RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}, Converter={StaticResource SubtractIntConverter}, ConverterParameter=2}"
                                                                Height="{Binding PreviewFrameSize, RelativeSource={RelativeSource AncestorType={x:Type local:VideoTimelineControl}}, Converter={StaticResource SubtractIntConverter}, ConverterParameter=2}">
                                                            </Image>
                                                        </Grid>
                                                        <Border.Style>
                                                            <Style TargetType="{x:Type Border}">
                                                                <Setter Property="BorderBrush" Value="{StaticResource ContainerBorder}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentColour1}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsHighlight}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentColour2}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="{x:Type ListBoxItem}">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource ContainerBorder}"/>
                                                    <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                                <Border Name="Border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}">
                                                                    <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" Margin="{TemplateBinding Padding}"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!--DragDrop Notification-->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding AllowDrop, ElementName=DragDropContainer, Converter={StaticResource BooleanToVisibilityConverter}}" IsHitTestVisible="False">
                        <CommonControls:FontAwesome Icon="e74c" Size="30" IconStyle="SharpLight" Color="{StaticResource AccentColour2}"/>
                        <TextBlock Text="Drag &amp; Drop Video Here" Foreground="{StaticResource AccentColour2}" FontSize="13" FontWeight="DemiBold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>
    </DockPanel>
</CommonControls:BaseControl>
