<CommonControls:BaseControl x:Class="Amuse.App.Controls.ExtractInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Amuse.App.Controls"
             xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF" >
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ExtractInputControl}}}">
        <Grid.Resources>
            <Style x:Key="ExtractInputTab" TargetType="{x:Type TabItem}" BasedOn="{StaticResource {x:Type TabItem}}">
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsExecuting}" Value="True"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <MultiDataTrigger.Setters>
                            <Setter Property="IsEnabled" Value="False"/>
                        </MultiDataTrigger.Setters>
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsAutomating}" Value="True"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <MultiDataTrigger.Setters>
                            <Setter Property="IsEnabled" Value="False"/>
                        </MultiDataTrigger.Setters>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <TabControl Margin="0,14,0,14" SelectedIndex="{Binding SelectedOption, Converter={StaticResource EnumToIntConverter}}">

            <TabItem Style="{StaticResource ExtractInputTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <CommonControls:FontAwesome Icon="f1de" IconStyle="Solid" Color="{StaticResource AccentColour2}" Size="13"/>
                        <TextBlock Text="Options" FontSize="11" FontWeight="DemiBold" Opacity=".9" Margin="5,0,0,0" />
                    </StackPanel>
                </TabItem.Header>
                <DockPanel>

                    <StackPanel VerticalAlignment="Top" Margin="0,10,0,0">

                        <!--Default Options-->
                        <StackPanel Visibility="{Binding ExtractorType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Default}">
                            <UniformGrid Columns="3" Visibility="{Binding Options.IsTileSupported, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" Margin="0,0,0,8">
                                <StackPanel>
                                    <CheckBox Content="Enable Tiling" IsChecked="{Binding Options.IsTileEnabled}" Margin="0,19,0,0"/>
                                </StackPanel>
                                <StackPanel IsEnabled="{Binding Options.IsTileEnabled}" Margin="0,0,2,0">
                                    <TextBlock Text="Tile Size" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox Text="{Binding Options.TileSize}" />
                                </StackPanel>
                                <StackPanel IsEnabled="{Binding Options.IsTileEnabled}" Margin="2,0,0,0">
                                    <TextBlock Text="Tile Overlap" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox Text="{Binding Options.TileOverlap}" />
                                </StackPanel>
                            </UniformGrid>
                            <UniformGrid Columns="3" >
                                <CheckBox Content="Invert Output" IsChecked="{Binding Options.IsInverted}" />
                                <!--<CheckBox Content="Merge Output" IsChecked="{Binding Options.MergeInput}" Margin="2,0,0,0"/>-->
                            </UniformGrid>
                        </StackPanel>


                        <!--Background Options-->
                        <StackPanel Visibility="{Binding ExtractorType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Background, FallbackValue=Collapsed}">
                            <UniformGrid Columns="2">
                                <StackPanel>
                                    <TextBlock Text="Background Mode" Style="{StaticResource FieldTextBlockStyle}" />
                                    <ComboBox SelectedItem="{Binding Options.Mode}" ItemsSource="{Binding Source={StaticResource BackgroundMode}}" Style="{StaticResource EnumComboBox}"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>

                        <!--Pose Options-->
                        <StackPanel Visibility="{Binding ExtractorType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Pose, FallbackValue=Collapsed}">
                            <UniformGrid Columns="3">
                                <StackPanel>
                                    <TextBlock Text="Max Detections" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox Text="{Binding Options.Detections, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Body Confidence" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox Text="{Binding Options.BodyConfidence, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Joint Confidence" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox Text="{Binding Options.JointConfidence, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Bone Radius" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox Text="{Binding Options.BoneRadius, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Bone Thickness" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox Text="{Binding Options.BoneThickness, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Joint Radius" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox Text="{Binding Options.JointRadius, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <CommonControls:SliderControl Value="{Binding Options.ColorAlpha}" Text="Alpha" Minimum="0" Maximum="1" TickFrequency="0.01" ValueFormat="N2" />
                                <CheckBox Content="IsTransparent" IsChecked="{Binding Options.IsTransparent}" Margin="8, 16, 0, 0" />
                            </UniformGrid>
                        </StackPanel>

                    </StackPanel>

                </DockPanel>
            </TabItem>

            <TabItem Style="{StaticResource ExtractInputTab}" Visibility="Collapsed">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <CommonControls:FontAwesome Icon="f085" IconStyle="Solid" Color="{StaticResource AccentColour2}" Size="12"/>
                        <TextBlock Text="Advanced" FontSize="11" FontWeight="DemiBold" Opacity=".9" Margin="5,0,0,0"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel>
                </DockPanel>
            </TabItem>

            <TabItem Style="{StaticResource ExtractInputTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <CommonControls:FontAwesome Icon="e0b6" IconStyle="Solid" Color="{StaticResource AccentColour2}" Size="12"/>
                        <TextBlock Text="Automation" FontSize="11" FontWeight="DemiBold" Opacity=".9" Margin="5,0,0,0"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel>

                    <!--Progress-->
                    <CommonControls:ProgressElement DockPanel.Dock="Bottom" Progress="{Binding AutomationProgress}" />

                    <StackPanel VerticalAlignment="Top" Margin="0,4,0,0">

                        <!--<StackPanel Margin="0,0,0,10">
                          <TextBlock Text="Automation" Style="{StaticResource FieldTextBlockStyle}" />
                          <ComboBox ItemsSource="{Binding AutomationOptions.Types}" SelectedItem="{Binding AutomationOptions.Type}" Style="{StaticResource EnumComboBox}" />
                      </StackPanel>-->

                        <!--InputFiles-->
                        <Grid Visibility="{Binding AutomationOptions.Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=InputFiles}">
                            <StackPanel Visibility="{Binding ViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=ImageExtract}">
                                <UniformGrid Margin="0,0,0,0" >
                                    <StackPanel>
                                        <TextBlock Text="Image Folder" Style="{StaticResource FieldTextBlockStyle}"/>
                                        <CommonControls:FilePickerTextBox FileName="{Binding AutomationOptions.InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsFolderPicker="True" IsRequired="True" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                            <StackPanel  Visibility="{Binding ViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=VideoExtract}">
                                <UniformGrid Margin="0,0,0,0" >
                                    <StackPanel>
                                        <TextBlock Text="Video Folder" Style="{StaticResource FieldTextBlockStyle}"/>
                                        <CommonControls:FilePickerTextBox FileName="{Binding AutomationOptions.InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsFolderPicker="True" IsRequired="True" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>


                        <!--HistoryEnabled-->
                        <CheckBox Content="Output History" IsChecked="{Binding AutomationOptions.IsHistoryEnabled}" Margin="0,4,0,0"/>

                        <!--OutputDirectory-->
                        <CheckBox  Content="Output Location" IsChecked="{Binding AutomationOptions.UseOutputDirectory}" Margin="0,4,0,0"/>
                        <Grid Visibility="{Binding AutomationOptions.UseOutputDirectory,Converter={StaticResource BooleanToVisibilityConverter}}">
                            <UniformGrid Margin="0,0,0,0" >
                                <StackPanel>
                                    <TextBlock Text="Output Folder" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:FilePickerTextBox FileName="{Binding AutomationOptions.OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsFolderPicker="True" IsRequired="True" />
                                </StackPanel>
                            </UniformGrid>
                        </Grid>
                    </StackPanel>
                </DockPanel>
            </TabItem>


            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <DockPanel>
                        <UniformGrid IsItemsHost="True" Rows="1" DockPanel.Dock="Top"></UniformGrid>
                        <ContentPresenter ContentSource="SelectedContent"></ContentPresenter>
                    </DockPanel>
                </ControlTemplate>
            </TabControl.Template>
        </TabControl>
    </Grid>
</CommonControls:BaseControl>
