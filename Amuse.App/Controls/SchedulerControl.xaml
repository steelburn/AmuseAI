                        <CheckBox Content="Set Alpha To One" IsChecked="{Binding SetAlphaToOne}" Margin="0,20,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <CheckBox Content="Rescale Betas SNR" IsChecked="{Binding RescaleBetasZeroSNR}" Margin="0,20,0,0"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type Common:SchedulerInputOptions}" x:Key="SCMLayout">
            <StackPanel>
                <UniformGrid Columns="3" Margin="0,4,0,0">
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Prediction" Style="{StaticResource FieldTextBlockStyle}" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource PredictionType}}" SelectedItem="{Binding PredictionType}" Style="{StaticResource EnumComboBox}"/>
                    </StackPanel>
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock Text="Sigma Data" Style="{StaticResource FieldTextBlockStyle}" />
                        <CommonControls:FloatBox FloatValue="{Binding SigmaData, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type Common:SchedulerInputOptions}" x:Key="SASolverLayout">
            <StackPanel>
                <UniformGrid Columns="3" Margin="0,4,0,0">
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Beta Schedule" Style="{StaticResource FieldTextBlockStyle}" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource BetaScheduleType}}" SelectedItem="{Binding BetaSchedule}" Style="{StaticResource EnumComboBox}"/>
                    </StackPanel>
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock Text="Beta Start" Style="{StaticResource FieldTextBlockStyle}" />
                        <CommonControls:FloatBox FloatValue="{Binding BetaStart, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Beta End" Style="{StaticResource FieldTextBlockStyle}" />
                        <CommonControls:FloatBox FloatValue="{Binding BetaEnd, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <UniformGrid  Columns="3">
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Prediction" Style="{StaticResource FieldTextBlockStyle}" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource PredictionType}}" SelectedItem="{Binding PredictionType}" Style="{StaticResource EnumComboBox}"/>
                    </StackPanel>
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock Text="Timestep Spacing" Style="{StaticResource FieldTextBlockStyle}" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource TimestepSpacingType}}" SelectedItem="{Binding TimestepSpacing}" Style="{StaticResource EnumComboBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="StepsOffset" Style="{StaticResource FieldTextBlockStyle}" />
                        <TextBox Text="{Binding StepsOffset, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <UniformGrid  Columns="3">
                    <StackPanel Margin="0,0,0,0">
                        <CheckBox Content="Thresholding" IsChecked="{Binding Thresholding}" Margin="0,20,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock Text="Thresholding Ratio" Style="{StaticResource FieldTextBlockStyle}" />
                        <CommonControls:FloatBox FloatValue="{Binding DynamicThresholdingRatio, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Sample MaxValue" Style="{StaticResource FieldTextBlockStyle}" />
                        <CommonControls:FloatBox FloatValue="{Binding SampleMaxValue, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,4,0,0">
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Flow Shift" Style="{StaticResource FieldTextBlockStyle}" />
                        <CommonControls:FloatBox FloatValue="{Binding FlowShift, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock Text="Algorithm Type" Style="{StaticResource FieldTextBlockStyle}" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource AlgorithmType}}" SelectedItem="{Binding AlgorithmType}" Style="{StaticResource EnumComboBox}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Variance Type" Style="{StaticResource FieldTextBlockStyle}" />
                        <ComboBox ItemsSource="{Binding Source={StaticResource VarianceType}}" SelectedItem="{Binding VarianceType}" Style="{StaticResource EnumComboBox}"/>
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,4,0,0">

                    <StackPanel Margin="4,0,4,0">
                        <TextBlock Text="Predictor Order" Style="{StaticResource FieldTextBlockStyle}" />
                        <TextBox Text="{Binding PredictorOrder, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="Corrector Order" Style="{StaticResource FieldTextBlockStyle}" />
                        <TextBox Text="{Binding CorrectorOrder, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,8,0,0">
                    <CheckBox Content="Flow Sigmas" IsChecked="{Binding UseFlowSigmas}" />
                    <CheckBox Content="Lower Order Final" IsChecked="{Binding LowerOrderFinal}" />
                </UniformGrid>

                <!--SigmasType-->
                <DockPanel Margin="0,4,0,0">
                    <TextBlock DockPanel.Dock="Top" Text="Sigma Type" Style="{StaticResource FieldTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <RadioButton GroupName="SigmasType" IsChecked="True" Content="Default"/>
                        <RadioButton GroupName="SigmasType" IsChecked="{Binding UseKarrasSigmas}" Content="Karras" Margin="20,0,0,0"/>
                        <RadioButton GroupName="SigmasType" IsChecked="{Binding UseBetaSigmas}" Content="Beta" Margin="20,0,0,0"/>
                        <RadioButton GroupName="SigmasType" IsChecked="{Binding UseExponentialSigmas}" Content="Exponential" Margin="20,0,0,0"/>
                    </StackPanel>
                </DockPanel>

            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type Common:SchedulerInputOptions}" x:Key="LTXEulerAncestralLayout">
            <StackPanel>
                <UniformGrid Columns="3" Margin="0,4,0,0">
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock Text="Eta" Style="{StaticResource FieldTextBlockStyle}" />
                        <CommonControls:FloatBox FloatValue="{Binding Eta, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="4,0,4,0">
                        <TextBlock Text="SNoise" Style="{StaticResource FieldTextBlockStyle}" />
                        <CommonControls:FloatBox FloatValue="{Binding SNoise, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </DataTemplate>
    </CommonControls:BaseControl.Resources>

    <DockPanel  DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:SchedulerControl}}}">


        <!--Scheduler Type-->
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Scheduler" Style="{StaticResource FieldTextBlockStyle}" />
            <ComboBox SelectedItem="{Binding SelectedOptions}" ItemsSource="{Binding Options}"/>
        </StackPanel>


        <!--Scheduler Options-->
        <ContentControl Content="{Binding SelectedOptions}" Visibility="{Binding IsSelectorOnly, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate" Value="{StaticResource DefaultLayout}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="LMS">
                            <Setter Property="ContentTemplate" Value="{StaticResource LMSLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="Euler">
                            <Setter Property="ContentTemplate" Value="{StaticResource EulerLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="EulerAncestral">
                            <Setter Property="ContentTemplate" Value="{StaticResource EulerAncestralLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="DDPM">
                            <Setter Property="ContentTemplate" Value="{StaticResource DDPMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="DDIM">
                            <Setter Property="ContentTemplate" Value="{StaticResource DDIMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="KDPM2">
                            <Setter Property="ContentTemplate" Value="{StaticResource LMSLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="KDPM2Ancestral">
                            <Setter Property="ContentTemplate" Value="{StaticResource LMSLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="DDPMWuerstchen">
                            <Setter Property="ContentTemplate" Value="{StaticResource DDPMWuerstchenLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="LCM">
                            <Setter Property="ContentTemplate" Value="{StaticResource LCMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="FlowMatchEuler">
                            <Setter Property="ContentTemplate" Value="{StaticResource FlowMatchEulerLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="FlowMatchHeun">
                            <Setter Property="ContentTemplate" Value="{StaticResource FlowMatchHeunLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="PNDM">
                            <Setter Property="ContentTemplate" Value="{StaticResource PNDMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="Heun">
                            <Setter Property="ContentTemplate" Value="{StaticResource HeunLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="UniPCMultistep">
                            <Setter Property="ContentTemplate" Value="{StaticResource UniPCMultistepLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="DPMSolverMultistep">
                            <Setter Property="ContentTemplate" Value="{StaticResource DPMSolverMultistepLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="DPMSolverSinglestep">
                            <Setter Property="ContentTemplate" Value="{StaticResource DPMSolverSinglestepLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="DPMSolverSDE">
                            <Setter Property="ContentTemplate" Value="{StaticResource DPMSolverSDELayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="DEISMultistep">
                            <Setter Property="ContentTemplate" Value="{StaticResource DEISMultistepLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="EDMEuler">
                            <Setter Property="ContentTemplate" Value="{StaticResource EDMEulerLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="EDMDPMSolverMultistep">
                            <Setter Property="ContentTemplate" Value="{StaticResource EDMDPMSolverMultistepLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="FlowMatchLCM">
                            <Setter Property="ContentTemplate" Value="{StaticResource FlowMatchLCMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="IPNDM">
                            <Setter Property="ContentTemplate" Value="{StaticResource IPNDMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="CogVideoXDDIM">
                            <Setter Property="ContentTemplate" Value="{StaticResource CogVideoXDDIMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="CogVideoXDPM">
                            <Setter Property="ContentTemplate" Value="{StaticResource CogVideoXDPMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="Helios">
                            <Setter Property="ContentTemplate" Value="{StaticResource HeliosLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="HeliosDMD">
                            <Setter Property="ContentTemplate" Value="{StaticResource HeliosDMDLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="TCD">
                            <Setter Property="ContentTemplate" Value="{StaticResource TCDLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="SCM">
                            <Setter Property="ContentTemplate" Value="{StaticResource SCMLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="SASolver">
                            <Setter Property="ContentTemplate" Value="{StaticResource SASolverLayout}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedOptions.Scheduler}" Value="LTXEulerAncestral">
                            <Setter Property="ContentTemplate" Value="{StaticResource LTXEulerAncestralLayout}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

    </DockPanel>
</CommonControls:BaseControl>
