<CommonControls:BaseControl x:Class="Amuse.App.Controls.SourceSelectControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Amuse.App.Controls"
             xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF" >
    <CommonControls:BaseControl.Resources>

        <Style x:Key="SourceSelectToggleButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Background" Value="{StaticResource ButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ComboBoxBorder}"/>
            <Setter Property="Foreground" Value="{StaticResource ButtonForeground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true" Padding="{TemplateBinding Padding}">
                            <DockPanel HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" >
                                <CommonControls:FontAwesome x:Name="indicator" Icon="e76e" Size="12" IconStyle="SharpRegular" DockPanel.Dock="Left" Color="{StaticResource ButtonBorderDefault}"/>
                                <ContentPresenter x:Name="contentPresenter" Focusable="False"  Margin="4,-1,0,0" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Color" TargetName="indicator" Value="{DynamicResource AccentColour2}"/>
                                <Setter Property="Opacity" TargetName="contentPresenter" Value=".9"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Opacity" TargetName="contentPresenter" Value=".8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Opacity" Value=".6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource ButtonBorderMouseOver}"/>
                                <Setter Property="Opacity" TargetName="contentPresenter" Value=".9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </CommonControls:BaseControl.Resources>

    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:SourceSelectControl}}}">
        <UniformGrid Columns="{Binding SourceCount}" >

            <!--Source1-->
            <ToggleButton x:Name="SourceToggle1" 
                Content="{Binding SourceText1, Mode=OneWay}" 
                IsChecked="{Binding IsSource1Selected, Mode=TwoWay}" 
                VerticalContentAlignment="{Binding TextVerticalAlignment}" 
                HorizontalContentAlignment="{Binding TextHorizontalAlignment}" 
                Checked="Source1_CheckedChanged" 
                Unchecked="Source1_CheckedChanged">
                <ToggleButton.Style>
                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource SourceSelectToggleButton}">
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMultiSelect}" Value="True"/>
                                    <Condition Binding="{Binding IsSourceRequired}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMultiSelect}" Value="False"/>
                                    <Condition Binding="{Binding IsSourceRequired}" Value="True"/>
                                    <Condition Binding="{Binding IsSource1Selected}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <!--Source2-->
            <ToggleButton x:Name="SourceToggle2" 
                Content="{Binding SourceText2, Mode=OneWay}" 
                IsChecked="{Binding IsSource2Selected, Mode=TwoWay}" 
                VerticalContentAlignment="{Binding TextVerticalAlignment}" 
                HorizontalContentAlignment="{Binding TextHorizontalAlignment}" 
                Checked="Source2_CheckedChanged" 
                Unchecked="Source2_CheckedChanged">
                <ToggleButton.Style>
                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource SourceSelectToggleButton}">
                        <Setter Property="IsEnabled" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SourceCount, Converter={StaticResource LessThanToBooleanConverter}, ConverterParameter=2}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMultiSelect}" Value="False"/>
                                    <Condition Binding="{Binding IsSourceRequired}" Value="True"/>
                                    <Condition Binding="{Binding IsSource2Selected}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <!--Source3-->
            <ToggleButton x:Name="SourceToggle3" 
                Content="{Binding SourceText3, Mode=OneWay}" 
                IsChecked="{Binding IsSource3Selected, Mode=TwoWay}" 
                VerticalContentAlignment="{Binding TextVerticalAlignment}" 
                HorizontalContentAlignment="{Binding TextHorizontalAlignment}" 
                Checked="Source3_CheckedChanged" 
                Unchecked="Source3_CheckedChanged">
                <ToggleButton.Style>
                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource SourceSelectToggleButton}">
                        <Setter Property="IsEnabled" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SourceCount, Converter={StaticResource LessThanToBooleanConverter}, ConverterParameter=3}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMultiSelect}" Value="False"/>
                                    <Condition Binding="{Binding IsSourceRequired}" Value="True"/>
                                    <Condition Binding="{Binding IsSource3Selected}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

            <!--Source4-->
            <ToggleButton x:Name="SourceToggle4" 
                Content="{Binding SourceText4, Mode=OneWay}" 
                IsChecked="{Binding IsSource4Selected, Mode=TwoWay}" 
                VerticalContentAlignment="{Binding TextVerticalAlignment}" 
                HorizontalContentAlignment="{Binding TextHorizontalAlignment}" 
                Checked="Source4_CheckedChanged" 
                Unchecked="Source4_CheckedChanged">
                <ToggleButton.Style>
                    <Style TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource SourceSelectToggleButton}">
                        <Setter Property="IsEnabled" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SourceCount, Converter={StaticResource LessThanToBooleanConverter}, ConverterParameter=4}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMultiSelect}" Value="False"/>
                                    <Condition Binding="{Binding IsSourceRequired}" Value="True"/>
                                    <Condition Binding="{Binding IsSource4Selected}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="IsHitTestVisible" Value="False" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>

        </UniformGrid>
    </Grid>
</CommonControls:BaseControl>
