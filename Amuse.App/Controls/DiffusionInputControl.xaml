<CommonControls:BaseControl x:Class="Amuse.App.Controls.DiffusionInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:base="clr-namespace:Amuse.App"
             xmlns:local="clr-namespace:Amuse.App.Controls"
             xmlns:Behaviors="clr-namespace:TensorStack.WPF.Behaviors;assembly=TensorStack.WPF"
             xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
             xmlns:CommonConverters="clr-namespace:TensorStack.WPF.Converters;assembly=TensorStack.WPF"
             xmlns:Controls="clr-namespace:Amuse.App.Controls"
             xmlns:Common="clr-namespace:Amuse.App.Common"
             xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid  DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DiffusionInputControl}}}">
        <Grid.Resources>
            <Style x:Key="DiffusionInputTab" TargetType="{x:Type TabItem}" BasedOn="{StaticResource {x:Type TabItem}}">
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsExecuting}" Value="True"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <MultiDataTrigger.Setters>
                            <Setter Property="IsEnabled" Value="False"/>
                        </MultiDataTrigger.Setters>
                    </MultiDataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsAutomating}" Value="True"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <MultiDataTrigger.Setters>
                            <Setter Property="IsEnabled" Value="False"/>
                        </MultiDataTrigger.Setters>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>


        <TabControl Margin="0,14,0,14" SelectedIndex="{Binding SelectedOption, Converter={StaticResource EnumToIntConverter}}">

            <!--Options-->
            <TabItem Style="{StaticResource DiffusionInputTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <CommonControls:FontAwesome Icon="f1de" IconStyle="Solid" Color="{StaticResource AccentColour2}" Size="13"/>
                        <TextBlock Text="Options" FontSize="11" FontWeight="DemiBold" Opacity=".9" Margin="5,0,0,0" />
                    </StackPanel>
                </TabItem.Header>
                <DockPanel>

                    <!--Input Options-->
                    <StackPanel DockPanel.Dock="Bottom"  Margin="0,4,0,0" >

                        <UniformGrid Columns="2">

                            <!--Presets-->
                            <StackPanel Margin="0,0,2,0" IsEnabled="False">
                                <TextBlock Text="Presets" Style="{StaticResource FieldTextBlockStyle}" />
                                <DockPanel>
                                    <UniformGrid DockPanel.Dock="Right" Columns="2">
                                        <CommonControls:AddOnButton Icon="f00c" IconSize="12" IconColor="{StaticResource DefaultForeground}" Width="25" IconOpacity=".8"/>
                                        <CommonControls:AddOnButton Icon="f0c7" IconSize="13" IconColor="{StaticResource DefaultForeground}" Width="25" IconOpacity=".8" />
                                    </UniformGrid>
                                    <ComboBox />
                                </DockPanel>
                            </StackPanel>

                            <!--Resolution-->
                            <DockPanel Margin="2,0,0,0">
                                <ToggleButton DockPanel.Dock="Right" IsChecked="{Binding IsResolutionEnabled}" Style="{StaticResource ToggleButtonBasic}" Width="25" Height="22" VerticalAlignment="Bottom">
                                    <CommonControls:FontAwesome Icon="&#xf1ec;" IconStyle="Light" Size="12"/>
                                </ToggleButton>
                                <Grid>
                                    <UniformGrid Columns="2" Visibility="{Binding IsResolutionEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <StackPanel Margin="0,0,1,0">
                                            <TextBlock Text="Width" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding Options.Width, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Height" Style="{StaticResource FieldTextBlockStyle}"/>
                                            <TextBox Text="{Binding Options.Height, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <StackPanel Visibility="{Binding IsResolutionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel.Resources>
                                            <CollectionViewSource x:Key="GroupedResolutions" Source="{Binding Pipeline.DiffusionModel.Resolutions}">
                                                <CollectionViewSource.GroupDescriptions>
                                                    <PropertyGroupDescription PropertyName="Aspect"/>
                                                </CollectionViewSource.GroupDescriptions>
                                            </CollectionViewSource>
                                        </StackPanel.Resources>
                                        <TextBlock Text="Resolution" Style="{StaticResource FieldTextBlockStyle}"/>
                                        <ComboBox ItemsSource="{Binding Source={StaticResource GroupedResolutions}}" SelectedItem="{Binding SelectedResolution}" IsSynchronizedWithCurrentItem="False" HorizontalContentAlignment="Stretch" SelectionChanged="ComboBoxResolution_SelectionChanged" >
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="{x:Type ComboBoxItem}" >
                                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Left" Text="{Binding}" />
                                                        <TextBlock Margin="5,1,0,0" Text="{Binding Aspect}" Opacity=".7" FontSize="9" TextAlignment="Right" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                            <ComboBox.GroupStyle>
                                                <GroupStyle>
                                                    <GroupStyle.HeaderTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="4,4,0,0" Text="{Binding Name}" FontSize="10" FontStyle="Italic" Opacity=".7"/>
                                                        </DataTemplate>
                                                    </GroupStyle.HeaderTemplate>
                                                </GroupStyle>
                                            </ComboBox.GroupStyle>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </DockPanel>


                            <!--Seed-->
                            <StackPanel Margin="0,0,2,0">
                                <TextBlock Text="Seed" Style="{StaticResource FieldTextBlockStyle}" />
                                <Controls:SeedControl Seed="{Binding Options.Seed}"/>
                            </StackPanel>

                            <!--Scheduler-->
                            <StackPanel Margin="2,0,0,0">
                                <Controls:SchedulerControl Options="{Binding Schedulers}" SelectedOptions="{Binding Options.SchedulerOptions, Mode=TwoWay}" IsSelectorOnly="True"/>
                            </StackPanel>

                        </UniformGrid>


                        <!--ImageEdit-->
                        <StackPanel Visibility="{Binding ViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=ImageEdit}" Margin="0,0,0,0">
                            <TextBlock Text="Inputs" Style="{StaticResource FieldTextBlockStyle}" />
                            <Controls:SourceSelectControl 
                                Height="22"
                                FontSize="12"
                                SourceCount="4"
                                IsMultiSelect="True" 
                                TextHorizontalAlignment="Center"
                                SourceText1="Image 1"
                                SourceText2="Image 2"
                                SourceText3="Image 3"
                                SourceText4="Image 4"
                                IsSource1Selected="{Binding Options.IsSource1Enabled, Mode=TwoWay}"
                                IsSource2Selected="{Binding Options.IsSource2Enabled, Mode=TwoWay}"
                                IsSource3Selected="{Binding Options.IsSource3Enabled, Mode=TwoWay}"
                                IsSource4Selected="{Binding Options.IsSource4Enabled, Mode=TwoWay}"/>
                        </StackPanel>


                        <!--FrameToFrame-->
                        <StackPanel Visibility="{Binding ViewType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=FrameToFrame}" Margin="0,0,0,0">
                            <TextBlock Text="Inputs" Style="{StaticResource FieldTextBlockStyle}" />
                            <Controls:SourceSelectControl 
                                Height="22"
                                FontSize="12"
                                SourceCount="4"
                                IsMultiSelect="True" 
                                TextHorizontalAlignment="Center"
                                SourceText1="Frame"
                                SourceText2="Image 1"
                                SourceText3="Image 2"
                                SourceText4="Image 3"
                                IsSource1Selected="{Binding Options.IsSource1Enabled, Mode=TwoWay}"
                                IsSource2Selected="{Binding Options.IsSource2Enabled, Mode=TwoWay}"
                                IsSource3Selected="{Binding Options.IsSource3Enabled, Mode=TwoWay}"
                                IsSource4Selected="{Binding Options.IsSource4Enabled, Mode=TwoWay}"/>
                        </StackPanel>


                        <!--Frames / FrameRate-->
                        <StackPanel Visibility="{Binding Pipeline.DiffusionModel.DefaultOptions.FrameOptions, Converter={StaticResource NullVisibilityConverter}, FallbackValue=Collapsed}">
                            <UniformGrid Columns="3">
                                <StackPanel Margin="0,0,2,0">
                                    <TextBlock Text="Frames" Style="{StaticResource FieldTextBlockStyle}" />
                                    <ComboBox ItemsSource="{Binding Pipeline.DiffusionModel.DefaultOptions.FrameOptions}" SelectedItem="{Binding Options.Frames}" />
                                </StackPanel>
                                <StackPanel Margin="2,0,2,0">
                                    <TextBlock Text="Frame Rate" Style="{StaticResource FieldTextBlockStyle}" />
                                    <ComboBox ItemsSource="{Binding FrameRates}" SelectedItem="{Binding Options.FrameRate}" >
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ., StringFormat={}{0} fps}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <DockPanel Margin="2,0,0,0">
                                    <TextBlock DockPanel.Dock="Top" Text="Duration" Style="{StaticResource FieldTextBlockStyle}" />
                                    <TextBox IsReadOnly="True" IsHitTestVisible="False" Opacity=".8">
                                        <TextBox.Text>
                                            <MultiBinding Converter="{StaticResource FramesToTimeSpanConverter}" StringFormat="{}{0:mm\:ss\.ff}">
                                                <Binding Path="Options.Frames" />
                                                <Binding Path="Options.FrameRate" />
                                            </MultiBinding>
                                        </TextBox.Text>
                                    </TextBox>
                                </DockPanel>
                            </UniformGrid>

                            <!--Frame Chunk-->
                            <StackPanel Visibility="{Binding Pipeline.DiffusionModel.DefaultOptions.FrameChunk, Converter={StaticResource GreaterThanToVisibilityConverter}, ConverterParameter=0, FallbackValue=Collapsed}">
                                <UniformGrid Columns="3" Margin="0,4,0,0">
                                    <CommonControls:SliderControl Text="Chunk Size" Value="{Binding Options.FrameChunk}" Minimum="1" Maximum="{Binding Pipeline.DiffusionModel.DefaultOptions.Frames}" TickFrequency="1" ValueFormat="N0" Margin="0,0,2,0"/>
                                    <CommonControls:SliderControl Text="Overlap" Value="{Binding Options.FrameChunkOverlap}" Minimum="1" Maximum="{Binding Pipeline.DiffusionModel.DefaultOptions.Frames}" TickFrequency="1" ValueFormat="N0" Margin="2,0,2,0"/>
                                    <CommonControls:SliderControl Text="Noise Condition" Value="{Binding Options.NoiseCondition}" Minimum="1" Maximum="100" TickFrequency="1" ValueFormat="N0" Margin="2,0,0,0"/>
                                </UniformGrid>
                            </StackPanel>

                        </StackPanel>


                        <!--ImageToVideo-->
                        <Grid Visibility="{Binding ProcessType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=ImageToVideo}">
                            <StackPanel Visibility="{Binding Pipeline.DiffusionModel.DefaultOptions.IsFirstFrameLastFrameEnabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                <TextBlock Text="Inputs" Style="{StaticResource FieldTextBlockStyle}" />
                                <Controls:SourceSelectControl 
                                    Height="22"
                                    FontSize="12"
                                    SourceCount="2"
                                    IsMultiSelect="True" 
                                    IsSourceRequired="True" 
                                    TextHorizontalAlignment="Center"
                                    SourceText1="First Frame"
                                    SourceText2="Last Frame"
                                    IsSource1Selected="{Binding Options.IsSource1Enabled, Mode=TwoWay}"
                                    IsSource2Selected="{Binding Options.IsSource2Enabled, Mode=TwoWay}"/>
                            </StackPanel>
                        </Grid>

                        <!--Steps-->
                        <StackPanel Visibility="{Binding IsSteps2Enabled, Converter={StaticResource InverseBooleanToVisibilityConverter}, ConverterParameter=0}">
                            <CommonControls:SliderControl Text="Steps" Value="{Binding Options.Steps}" Minimum="1" Maximum="100" TickFrequency="1" />
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsSteps2Enabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                            <UniformGrid Columns="2">
                                <CommonControls:SliderControl Text="Steps (Stage1)" Value="{Binding Options.Steps}" Minimum="1" Maximum="100" TickFrequency="1" Margin="0,0,3,0"/>
                                <CommonControls:SliderControl Text="Steps (Stage2)" Value="{Binding Options.Steps2}" Minimum="1" Maximum="100" TickFrequency="1" Margin="3,0,0,0"/>
                            </UniformGrid>
                        </StackPanel>

                        <!--Guidance Scale-->
                        <StackPanel Visibility="{Binding IsGuidance2Enabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <CommonControls:SliderControl Text="Guidance" Value="{Binding Options.GuidanceScale}" Minimum="1" Maximum="20" TickFrequency="0.1" ValueFormat="F2"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsGuidance2Enabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                            <UniformGrid Columns="2">
                                <CommonControls:SliderControl Text="Guidance (Model)" Value="{Binding Options.GuidanceScale2}" Minimum="1" Maximum="20" TickFrequency="0.1" ValueFormat="F2" Margin="0,0,3,0"/>
                                <CommonControls:SliderControl Text="Guidance (CFG)" Value="{Binding Options.GuidanceScale}" Minimum="1" Maximum="20" TickFrequency="0.1" ValueFormat="F2" Margin="3,0,0,0"/>
                            </UniformGrid>
                        </StackPanel>


                        <!--ImageToImage-->
                        <Grid Visibility="{Binding ProcessType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=ImageToImage}">

                            <!--Default-->
                            <StackPanel Visibility="{Binding Pipeline.ControlNetModel, Converter={StaticResource InverseNullVisibilityConverter}}">
                                <CommonControls:SliderControl Text="Strength" Value="{Binding Options.Strength}"  IsPercent="True"  Minimum="0.01" Maximum="1" TickFrequency="0.01" />
                            </StackPanel>

                            <!--ControlNet-->
                            <StackPanel Visibility="{Binding Pipeline.ControlNetModel, Converter={StaticResource NullVisibilityConverter}, FallbackValue=Collapsed}">
                                <CommonControls:SliderControl Text="Control Strength" Value="{Binding Options.ControlNetStrength}" IsPercent="True" Minimum="0.01" Maximum="1" TickFrequency="0.01"/>
                                <!--<DockPanel Visibility="{Binding IsImageToImageControlNetSupported, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <CheckBox DockPanel.Dock="Left" Content="Input Image" Margin="0,10,20,0"/>
                                    <CommonControls:SliderControl Text="Input Strength" Value="{Binding Options.Strength}"  IsPercent="True"  Minimum="0.01" Maximum="1" TickFrequency="0.01" />
                                </DockPanel>-->
                            </StackPanel>
                        </Grid>


                        <!--VideoToVideo-->
                        <StackPanel Visibility="{Binding ProcessType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=VideoToVideo}">
                            <StackPanel Visibility="{Binding Pipeline.DiffusionModel.DefaultOptions.Strength, Converter={StaticResource LessThanToVisibilityConverter}, ConverterParameter=1}">
                                <CommonControls:SliderControl Text="Strength" Value="{Binding Options.Strength}"  IsPercent="True"  Minimum="0.01" Maximum="1" TickFrequency="0.01"/>
                            </StackPanel>
                        </StackPanel>


                        <!--ImageInpaint-->
                        <StackPanel Visibility="{Binding ProcessType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=ImageInpaint}">
                            <CommonControls:SliderControl Text="Strength" Value="{Binding Options.Strength}"  IsPercent="True"  Minimum="0.01" Maximum="1" TickFrequency="0.01"/>
                        </StackPanel>



                        <!--Lora Strength-->
                        <ItemsControl ItemsSource="{Binding Options.LoraOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding Name, StringFormat={}({0})}" FontSize="8" Margin="0,6,0,0" Opacity=".9" HorizontalAlignment="Center"/>
                                        <CommonControls:SliderControl Text="Lora"  IsPercent="True" Minimum="0.01" Maximum="2" TickFrequency="0.01" Value="{Binding Strength}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid IsItemsHost="True">
                                        <UniformGrid.Style>
                                            <Style TargetType="{x:Type UniformGrid}">
                                                <Setter Property="Columns" Value="2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Options.LoraOptions.Count}" Value="1">
                                                        <Setter Property="Columns" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </UniformGrid.Style>
                                    </UniformGrid>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                    </StackPanel>

                    <!--Prompt Options-->
                    <DockPanel Margin="0,4,0,10">

                        <!--LoRA Triggers-->
                        <DockPanel DockPanel.Dock="Bottom" >
                            <ItemsControl ItemsSource="{Binding Pipeline.LoraAdapterModel}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ListBox ItemsSource="{Binding Triggers}" ItemContainerStyle="{StaticResource TransparentListBoxItem}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel IsItemsHost="True" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}" Command="{Binding AddTriggerWordCommand, RelativeSource={RelativeSource AncestorType={x:Type local:DiffusionInputControl}}}" CommandParameter="{Binding}" Background="{StaticResource ButtonBackgroundDisabled}" FontSize="9" Margin="0,2,3,0" Padding="3,0" ToolTip="Add LoRA Trigger word"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>

                        <!--Prompts-->
                        <UniformGrid Columns="1" >
                            <DockPanel>
                                <TextBlock  DockPanel.Dock="Top" Text="Prompt" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBox  Text="{Binding Options.Prompt}" TextWrapping="Wrap" AcceptsReturn="True" />
                            </DockPanel>
                            <DockPanel x:Name="PanelNegativePrompt" Visibility="{Binding Options.GuidanceScale, Converter={StaticResource GreaterThanToVisibilityConverter}, ConverterParameter=1, FallbackValue=Collapsed}">
                                <TextBlock DockPanel.Dock="Top" Text="Negative Prompt" Style="{StaticResource FieldTextBlockStyle}" />
                                <TextBox Text="{Binding Options.NegativePrompt, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" />
                            </DockPanel>
                            <UniformGrid.Style>
                                <Style TargetType="{x:Type UniformGrid}">
                                    <Setter Property="Rows" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Visibility, ElementName=PanelNegativePrompt}" Value="Visible">
                                            <Setter Property="Rows" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </UniformGrid.Style>
                        </UniformGrid>
                    </DockPanel>

                </DockPanel>

            </TabItem>


            <!--Advanced-->
            <TabItem Style="{StaticResource DiffusionInputTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <CommonControls:FontAwesome Icon="f085" IconStyle="Solid" Color="{StaticResource AccentColour2}" Size="12"/>
                        <TextBlock Text="Advanced" FontSize="11" FontWeight="DemiBold" Opacity=".9" Margin="5,0,0,0"/>
                    </StackPanel>
                </TabItem.Header>
                <StackPanel VerticalAlignment="Top" Margin="0,4,0,0">

                    <!--ExtractOptions-->
                    <GroupBox Header="Extract Options" Margin="0,0,0,10" Visibility="{Binding Pipeline.ExtractModel, Converter={StaticResource NullVisibilityConverter}, FallbackValue=Collapsed}">
                        <Controls:ExtractInputControl Pipeline="{Binding Pipeline, Mode=OneWay}" Options="{Binding ExtractOptions, Mode=OneWayToSource}" />
                    </GroupBox>

                    <!--SchedulerOptions-->
                    <GroupBox Header="Scheduler Options" Margin="0,0,0,10">
                        <Controls:SchedulerControl Options="{Binding Schedulers}" SelectedOptions="{Binding Options.SchedulerOptions, Mode=TwoWay}" IsSelectorOnly="False"/>
                    </GroupBox>

                    <!--AutoEncoder-->
                    <GroupBox Header="Auto Encoder" Margin="0,0,0,10" >
                        <UniformGrid Columns="2" Margin="0,6,0,4">
                            <CheckBox Content="Enable Tiling" IsChecked="{Binding Options.IsVaeTilingEnabled}" />
                            <CheckBox Content="Enable Slicing" IsChecked="{Binding Options.IsVaeSlicingEnabled}" />
                        </UniformGrid>
                    </GroupBox>

                    <!--UpscaleOptions-->
                    <GroupBox Header="Upscale Options" Margin="0,0,0,10" Visibility="{Binding Pipeline.UpscaleModel, Converter={StaticResource NullVisibilityConverter}, FallbackValue=Collapsed}">
                        <Controls:UpscaleInputControl Pipeline="{Binding Pipeline, Mode=OneWay}" Options="{Binding UpscaleOptions, Mode=OneWayToSource}" />
                    </GroupBox>

                </StackPanel>

            </TabItem>


            <!--Automation-->
            <TabItem Style="{StaticResource DiffusionInputTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <CommonControls:FontAwesome Icon="e0b6" IconStyle="Solid" Color="{StaticResource AccentColour2}" Size="12"/>
                        <TextBlock Text="Automation" FontSize="11" FontWeight="DemiBold" Opacity=".9" Margin="5,0,0,0"/>
                    </StackPanel>
                </TabItem.Header>
                <DockPanel>

                    <!--Progress-->
                    <CommonControls:ProgressElement DockPanel.Dock="Bottom" Progress="{Binding AutomationProgress}" />

                    <StackPanel VerticalAlignment="Top" Margin="0,4,0,0">

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Automation" Style="{StaticResource FieldTextBlockStyle}" />
                            <ComboBox ItemsSource="{Binding AutomationOptions.Types}" SelectedItem="{Binding AutomationOptions.Type}" Style="{StaticResource EnumComboBox}" />
                        </StackPanel>

                        <!--Seed-->
                        <Grid Visibility="{Binding AutomationOptions.Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Seed}">
                            <UniformGrid Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Image Count" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <TextBox Text="{Binding AutomationOptions.Count, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </UniformGrid>
                        </Grid>

                        <!--PromptFiles-->
                        <Grid Visibility="{Binding AutomationOptions.Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=PromptFiles}">
                            <UniformGrid Margin="0,0,0,0" >
                                <StackPanel>
                                    <TextBlock Text="Prompt Folder" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:FilePickerTextBox FileName="{Binding AutomationOptions.InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsFolderPicker="True" IsRequired="True" />
                                </StackPanel>
                            </UniformGrid>
                        </Grid>

                        <!--PromptLines-->
                        <Grid Visibility="{Binding AutomationOptions.Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=PromptLines}">
                            <UniformGrid Margin="0,0,0,0" >
                                <StackPanel>
                                    <TextBlock Text="Prompt File" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:FilePickerTextBox FileName="{Binding AutomationOptions.InputFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsRequired="True" Filter="Text Files|*.txt;" DefaultExt="txt"/>
                                </StackPanel>
                            </UniformGrid>
                        </Grid>

                        <!--ImageFiles-->
                        <Grid Visibility="{Binding AutomationOptions.Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=InputFiles}">
                            <StackPanel Visibility="{Binding ProcessType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=ImageToImage|ImageEdit|ImageToVideo}">
                                <UniformGrid Margin="0,0,0,0" >
                                    <StackPanel>
                                        <TextBlock Text="Image Folder" Style="{StaticResource FieldTextBlockStyle}"/>
                                        <CommonControls:FilePickerTextBox FileName="{Binding AutomationOptions.InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsFolderPicker="True" IsRequired="True" />
                                    </StackPanel>
                                </UniformGrid>
                                <CheckBox Content="Use Input Size" IsChecked="{Binding AutomationOptions.UseInputSize}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel  Visibility="{Binding ProcessType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=VideoToVideo}">
                                <UniformGrid Margin="0,0,0,0" >
                                    <StackPanel>
                                        <TextBlock Text="Video Folder" Style="{StaticResource FieldTextBlockStyle}"/>
                                        <CommonControls:FilePickerTextBox FileName="{Binding AutomationOptions.InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsFolderPicker="True" IsRequired="True" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>


                        <!--HistoryEnabled-->
                        <CheckBox Content="Output History" IsChecked="{Binding AutomationOptions.IsHistoryEnabled}" Margin="0,4,0,0"/>


                        <!--OutputDirectory-->
                        <CheckBox  Content="Output Location" IsChecked="{Binding AutomationOptions.UseOutputDirectory}" Margin="0,4,0,0"/>
                        <Grid Visibility="{Binding AutomationOptions.UseOutputDirectory,Converter={StaticResource BooleanToVisibilityConverter}}">
                            <UniformGrid Margin="0,0,0,0" >
                                <StackPanel>
                                    <TextBlock Text="Output Folder" Style="{StaticResource FieldTextBlockStyle}"/>
                                    <CommonControls:FilePickerTextBox FileName="{Binding AutomationOptions.OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsFolderPicker="True" IsRequired="True" />
                                </StackPanel>
                            </UniformGrid>
                        </Grid>
                    </StackPanel>

                </DockPanel>
            </TabItem>


            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <DockPanel>
                        <UniformGrid IsItemsHost="True" Rows="1" DockPanel.Dock="Top"></UniformGrid>
                        <ContentPresenter ContentSource="SelectedContent"></ContentPresenter>
                    </DockPanel>
                </ControlTemplate>
            </TabControl.Template>
        </TabControl>
    </Grid>
</CommonControls:BaseControl>
