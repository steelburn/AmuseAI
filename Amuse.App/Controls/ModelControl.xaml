<CommonControls:BaseControl x:Class="Amuse.App.Controls.ModelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:base="clr-namespace:Amuse.App"
             xmlns:local="clr-namespace:Amuse.App.Controls"
             xmlns:Behaviors="clr-namespace:TensorStack.WPF.Behaviors;assembly=TensorStack.WPF"
             xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF"
             xmlns:CommonConverters="clr-namespace:TensorStack.WPF.Converters;assembly=TensorStack.WPF"
             xmlns:Controls="clr-namespace:Amuse.App.Controls"
             xmlns:Common="clr-namespace:Amuse.App.Common"
             xmlns:Views="clr-namespace:Amuse.App.Views">
    <Grid  DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:ModelControl}}}">

        <DockPanel>

            <DockPanel DockPanel.Dock="Bottom">

                <!--Load/Unload-->
                <DockPanel DockPanel.Dock="Right" Width="80" Height="22" Margin="0,2,0,0">
                    <Button x:Name="UnloadButton" DockPanel.Dock="Right" Command="{Binding UnloadCommand}" Width="22">
                        <CommonControls:FontAwesome Icon="f00d" IconStyle="Solid" >
                            <CommonControls:FontAwesome.Style>
                                <Style TargetType="{x:Type CommonControls:FontAwesome}" BasedOn="{StaticResource {x:Type CommonControls:FontAwesome}}">
                                    <Setter Property="Opacity" Value="0.5" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, ElementName=UnloadButton}" Value="True">
                                            <Setter Property="Opacity" Value="0.7" />
                                            <Setter Property="Color" Value="{StaticResource DangerColour}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CommonControls:FontAwesome.Style>
                        </CommonControls:FontAwesome>
                    </Button>
                    <Grid>
                        <Button x:Name="LoadButton" Command="{Binding LoadCommand}" >
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Content" Value="Load" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled, ElementName=LoadButton}" Value="False">
                                            <Setter Property="Content" Value="Loading" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Grid Visibility="{Binding IsEnabled, ElementName=LoadButton, Converter={StaticResource InverseBooleanToHiddenConverter}, FallbackValue=Hidden}">
                            <Border Background="{StaticResource ButtonBackground}" BorderBrush="{StaticResource ButtonBorderBrush}" BorderThickness="1" Visibility="{Binding IsPipelineLoaded, Converter={StaticResource BooleanToHiddenConverter}, FallbackValue=Hidden}">
                                <DockPanel Margin="4,0" HorizontalAlignment="Center" Opacity=".8">
                                    <CommonControls:FontAwesome DockPanel.Dock="Left" Icon="f058" Size="12" Color="{StaticResource SuccessColour}" Margin="0,1,0,0"/>
                                    <TextBlock Text="Ready" Margin="4,2,0,0" Foreground="{StaticResource SuccessColour}"/>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                   
                </DockPanel>

                <!--Options-->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="1,0,0,0">
                </StackPanel>

            </DockPanel>

            <UniformGrid Columns="1">

                <!--Device-->
                <DockPanel>
                    <TextBox DockPanel.Dock="Left" Text="Device" IsReadOnly="True" IsHitTestVisible="False" Width="60" FontStyle="Italic" FontSize="11" Opacity="0.7" Padding="4,2,0,0"/>
                    <Grid>
                        <ComboBox 
                            DisplayMemberPath="Name"
                            IsSynchronizedWithCurrentItem="False"
                            SelectedItem="{Binding SelectedDevice}" 
                            ItemsSource="{Binding DeviceCollectionView}" 
                            SelectionChanged="Device_SelectionChanged" />
                        <TextBlock Text="No devices found." FontStyle="Italic" Opacity=".4" Margin="5,2,0,0" IsHitTestVisible="False" Visibility="{Binding DeviceCollectionView.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </DockPanel>

                <!--Extractor-->
                <DockPanel Visibility="{Binding IsExtractorEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBox DockPanel.Dock="Left" Text="Extractor" IsReadOnly="True" IsHitTestVisible="False" Width="60" FontStyle="Italic" FontSize="11" Opacity="0.7" Padding="4,2,0,0"/>
                    <Grid>
                        <ComboBox 
                            SelectedItem="{Binding SelectedExtractor}"
                            ItemsSource="{Binding ExtractCollectionView}"
                            ItemTemplate="{StaticResource ComboBoxDataTemplateModel}"
                            HorizontalContentAlignment="Stretch"
                            IsSynchronizedWithCurrentItem="False"/>
                        <TextBlock Text="No models found." FontStyle="Italic" Opacity=".4" Margin="5,2,0,0" IsHitTestVisible="False" Visibility="{Binding ExtractCollectionView.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </DockPanel>

                <!--Upscale-->
                <DockPanel Visibility="{Binding IsUpscalerEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBox DockPanel.Dock="Left" Text="Upscaler" IsReadOnly="True" IsHitTestVisible="False" Width="60" FontStyle="Italic" FontSize="11" Opacity="0.7" Padding="4,2,0,0"/>
                    <Grid>
                        <ComboBox 
                            SelectedItem="{Binding SelectedUpscaler}" 
                            ItemsSource="{Binding UpscaleCollectionView}" 
                            ItemTemplate="{StaticResource ComboBoxDataTemplateModel}"
                            HorizontalContentAlignment="Stretch"
                            IsSynchronizedWithCurrentItem="False" />
                        <TextBlock Text="No models found." FontStyle="Italic" Opacity=".4" Margin="5,2,0,0" IsHitTestVisible="False" Visibility="{Binding UpscaleCollectionView.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </DockPanel>

            </UniformGrid>
        </DockPanel>

    </Grid>
</CommonControls:BaseControl>
