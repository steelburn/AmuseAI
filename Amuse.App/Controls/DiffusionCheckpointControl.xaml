                </TabItem.Header>
                <Border BorderThickness="1" BorderBrush="{StaticResource ContainerBorder}" Padding="4">
                    <local:CheckpointControl Checkpoint="{Binding Checkpoint.LatentUpsamplerTemporal}" Settings="{Binding Settings}" Backend="{Binding Backend}" IsDiffusionCheckpoint="True"/>
                </Border>
            </TabItem>

            <!--ConditionEncoder-->
            <TabItem Visibility="{Binding Checkpoint.ConditionEncoder, Converter={StaticResource NullVisibilityConverter}}">
