            </TabItem>

            <!--TextEncoder3-->
            <TabItem Visibility="{Binding Checkpoint.TextEncoder3, Converter={StaticResource NullVisibilityConverter}}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <TextBlock Text="TextEncoder3" />
                    </StackPanel>
                </TabItem.Header>
                <Border BorderThickness="1" BorderBrush="{StaticResource ContainerBorder}" Padding="4">
                    <local:CheckpointControl Checkpoint="{Binding Checkpoint.TextEncoder3}" Settings="{Binding Settings}" Backend="{Binding Backend}" IsDiffusionCheckpoint="True" SupportedTypes="{Binding TextEncodedCheckpointTypes}"/>
                </Border>
            </TabItem>

            <!--Unet-->
            <TabItem Visibility="{Binding Checkpoint.Unet, Converter={StaticResource NullVisibilityConverter}}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
