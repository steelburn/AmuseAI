<CommonControls:BaseControl x:Class="Amuse.App.Controls.DiffusionCheckpointControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Amuse.App.Controls"
             xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls;assembly=TensorStack.WPF" >
    <Grid DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DiffusionCheckpointControl}}}">
        <TabControl SelectedIndex="{Binding SelectedIndex}">

            <!--Compute-->
            <TabItem Visibility="{Binding Checkpoint.Compute, Converter={StaticResource NullVisibilityConverter}}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <TextBlock Text="Compute" />
                    </StackPanel>
                </TabItem.Header>
                <Border BorderThickness="1" BorderBrush="{StaticResource ContainerBorder}" Padding="4">
                    <local:CheckpointControl Checkpoint="{Binding Checkpoint.Compute}" Settings="{Binding Settings}" Backend="{Binding Backend}" IsDiffusionCheckpoint="False" SupportedTypes="{Binding ComputeCheckpointTypes}"/>
                </Border>
            </TabItem>

            <!--TextEncoder-->
            <TabItem Visibility="{Binding Checkpoint.TextEncoder, Converter={StaticResource NullVisibilityConverter}}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Margin="3">
                        <TextBlock Text="TextEncoder" />
                    </StackPanel>
                </TabItem.Header>
                <Border BorderThickness="1" BorderBrush="{StaticResource ContainerBorder}" Padding="4">
                    <local:CheckpointControl Checkpoint="{Binding Checkpoint.TextEncoder}" Settings="{Binding Settings}" Backend="{Binding Backend}" IsDiffusionCheckpoint="True" SupportedTypes="{Binding TextEncodedCheckpointTypes}"/>
                </Border>
            </TabItem>

            <!--TextEncoder2-->
            <TabItem Visibility="{Binding Checkpoint.TextEncoder2, Converter={StaticResource NullVisibilityConverter}}">
